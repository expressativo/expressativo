<%= form_with model: [@project, template], class: "space-y-4" do |f| %>
  <div>
    <%= f.label :name, "Nombre del template", class: "block text-xs font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name,
        placeholder: "ej: Bug report, Feature request",
        required: true,
        class: "w-full px-3 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500" %>
    <p class="mt-1 text-[11px] text-gray-400">Nombre que se mostrará al crear una tarea.</p>
  </div>

  <div>
    <%= f.label :title, class: "block text-xs font-medium text-gray-700 mb-1" do %>
      Título pre-llenado <span class="text-gray-400 font-normal">(opcional)</span>
    <% end %>
    <%= f.text_field :title,
        placeholder: "ej: [BUG] ",
        class: "w-full px-3 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500" %>
  </div>

  <div>
    <%= f.label :notes, class: "block text-xs font-medium text-gray-700 mb-1" do %>
      Notas pre-llenadas <span class="text-gray-400 font-normal">(opcional)</span>
    <% end %>
    <%= f.rich_text_area :notes,
        placeholder: "Contenido inicial de la tarea...",
        class: "prose prose-sm max-w-none" %>
  </div>

  <%= f.submit template.persisted? ? "Guardar cambios" : "Crear template",
      class: "w-full inline-flex items-center justify-center gap-1.5 px-3 py-2 text-sm font-medium text-white bg-purple-600 rounded-lg hover:bg-purple-700 transition-colors cursor-pointer" %>
<% end %>
