<% content_for :title, "Editar template" %>

<%= render layout: 'projects/layout', locals: { project: @project, active: :task_templates } do %>
  <div class="max-w-xl">
    <div class="mb-4">
      <%= link_to project_task_templates_path(@project), class: "inline-flex items-center gap-1.5 text-sm text-gray-600 hover:text-purple-600 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Volver a templates
      <% end %>
    </div>

    <section class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
      <header class="px-6 py-4 border-b border-gray-200">
        <h1 class="text-lg font-semibold text-gray-900">Editar template</h1>
        <p class="text-sm text-gray-500 mt-0.5">Modifica "<%= @template.name %>"</p>
      </header>
      <div class="p-6">
        <%= render 'form', template: @template %>
      </div>
    </section>
  </div>
<% end %>
