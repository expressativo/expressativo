<% content_for :title, "Templates de tarea" %>

<%= render layout: 'projects/layout', locals: { project: @project, active: :task_templates } do %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="lg:col-span-2 space-y-4">
      <section class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
        <header class="flex items-center gap-4 px-6 py-4 border-b border-gray-100">
          <span class="w-9 h-9 rounded-lg bg-purple-50 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
          </span>
          <div class="flex items-center gap-2 min-w-0">
            <h2 class="text-lg font-semibold text-gray-900 truncate">Templates de tarea</h2>
            <span class="text-xs font-medium text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full">
              <%= @templates.size %>
            </span>
          </div>
        </header>

        <% if @templates.any? %>
          <ul class="divide-y divide-gray-100">
            <% @templates.each do |template| %>
              <li class="flex items-start justify-between gap-4 px-6 py-4 group hover:bg-gray-50 transition-colors">
                <div class="min-w-0 flex-1">
                  <p class="text-sm font-semibold text-gray-900 truncate"><%= template.name %></p>
                  <% if template.title.present? %>
                    <p class="text-xs text-gray-500 mt-0.5 truncate">Título: <%= template.title %></p>
                  <% end %>
                  <% if template.notes.body.present? %>
                    <p class="text-xs text-gray-400 mt-0.5 truncate"><%= template.notes.to_plain_text.truncate(80) %></p>
                  <% end %>
                </div>
                <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0">
                  <%= link_to edit_project_task_template_path(@project, template),
                        class: "p-1.5 rounded-md text-gray-500 hover:bg-gray-100 transition-colors",
                        title: "Editar template" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                  <% end %>
                  <%= button_to project_task_template_path(@project, template),
                        method: :delete,
                        form: { data: { turbo_confirm: "¿Eliminar el template \"#{template.name}\"?" } },
                        class: "p-1.5 rounded-md text-red-500 hover:bg-red-50 transition-colors cursor-pointer",
                        title: "Eliminar template" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"/>
                    </svg>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="text-center py-12 text-gray-400">
            <svg class="w-10 h-10 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            <p class="text-sm">No hay templates todavía.</p>
            <p class="text-xs mt-1">Crea el primero usando el formulario.</p>
          </div>
        <% end %>
      </section>
    </div>

    <div>
      <section class="bg-white border border-gray-200 rounded-2xl p-5">
        <div class="flex items-center gap-2 mb-4">
          <span class="w-8 h-8 rounded-lg bg-purple-50 flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
          </span>
          <h3 class="text-base font-semibold text-gray-900">Nuevo template</h3>
        </div>

        <%= render 'form', template: @template %>
      </section>
    </div>
  </div>
<% end %>
