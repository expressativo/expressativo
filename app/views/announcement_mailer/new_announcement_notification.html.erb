<!DOCTYPE html>
<html>
  <head>
    <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
    <style>
      body {
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #333;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }
      .header {
        background-color: #4F46E5;
        color: white;
        padding: 20px;
        border-radius: 8px 8px 0 0;
      }
      .content {
        background-color: #f9fafb;
        padding: 20px;
        border: 1px solid #e5e7eb;
      }
      .announcement-box {
        background-color: white;
        padding: 15px;
        border-left: 4px solid #F59E0B;
        margin: 15px 0;
        white-space: pre-wrap;
      }
      .button {
        display: inline-block;
        background-color: #4F46E5;
        color: white;
        padding: 12px 24px;
        text-decoration: none;
        border-radius: 6px;
        margin-top: 15px;
      }
      .footer {
        text-align: center;
        color: #6b7280;
        font-size: 12px;
        margin-top: 20px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h2>Nuevo anuncio en <%= @project.title %></h2>
      </div>

      <div class="content">
        <p>Hola <%= @recipient.full_name.presence || @recipient.email %>,</p>

        <% if @author.present? %>
          <p>
            <strong><%= @author.full_name.presence || @author.email %></strong>
            ha publicado un nuevo anuncio en el proyecto
            <strong><%= @project.title %></strong>.
          </p>
        <% else %>
          <p>
            Se ha publicado un nuevo anuncio en el proyecto
            <strong><%= @project.title %></strong>.
          </p>
        <% end %>

        <div class="announcement-box trix-content"><%= @announcement.content %></div>

        <%= link_to 'Ver anuncio',
            project_announcement_url(@project, @announcement),
            class: 'button' %>

        <p class="footer">
          Este es un correo automático de Expressativo.
          No respondas a este mensaje.
        </p>
      </div>
    </div>
  </body>
</html>
