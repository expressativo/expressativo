<% content_for :title, "#{@task.title} — #{@project.title}" %>

<div class="min-h-screen bg-gray-50 py-8 px-4">
  <div class="max-w-3xl mx-auto">
    <header class="flex items-center justify-between mb-6">
      <%= link_to root_path, class: "flex items-center gap-2 text-gray-700 hover:text-gray-900" do %>
        <%= image_tag "expressativo_logo.jpg", class: "w-8 h-8 rounded" %>
        <span class="font-semibold">Tivo</span>
      <% end %>
      <% unless user_signed_in? %>
        <%= link_to "Iniciar sesión", new_user_session_path,
              class: "text-sm font-medium text-gray-600 hover:text-gray-900" %>
      <% end %>
    </header>

    <section class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm">
      <header class="px-6 py-5 border-b border-gray-100">
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2 mb-1">
              <span class="inline-flex items-center gap-1 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider rounded bg-sky-100 text-sky-700">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/>
                </svg>
                Solo lectura
              </span>
              <span class="text-xs font-mono text-gray-400">TASK-<%= @task.id %></span>
            </div>

            <div class="flex items-center gap-3">
              <span class="inline-flex w-7 h-7 items-center justify-center rounded-md border-2 flex-shrink-0 <%= @task.completed? ? 'bg-emerald-500 border-emerald-500 text-white' : 'border-gray-300 bg-white' %>">
                <% if @task.completed? %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                <% end %>
              </span>
              <h1 class="text-2xl font-bold text-gray-900 leading-tight <%= 'line-through text-gray-400' if @task.completed? %>">
                <%= @task.title %>
              </h1>
            </div>
          </div>
        </div>

        <div class="flex flex-wrap gap-4 mt-4 text-xs text-gray-500">
          <% if @task.created_by.present? %>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              <%= @task.created_by.full_name.presence || @task.created_by.email %>
            </span>
          <% end %>
          <% if @task.due_date.present? %>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              Vence el <%= l(@task.due_date.to_date, format: :long) rescue @task.due_date.strftime("%d/%m/%Y") %><% if @task.due_date_has_time? %> · <%= @task.due_date.strftime("%H:%M") %><% end %>
            </span>
          <% end %>
          <% if @task.assigned_users.any? %>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <%= @task.assigned_users.map { |u| u.full_name.presence || u.email }.join(", ") %>
            </span>
          <% end %>
        </div>
      </header>

      <% if @task.notes.present? %>
        <div class="px-6 py-5">
          <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Descripción</h2>
          <div class="prose prose-sm max-w-none text-gray-800">
            <%= @task.notes %>
          </div>
        </div>
      <% else %>
        <div class="px-6 py-8 text-center text-sm text-gray-400 italic">
          Esta tarea no tiene descripción.
        </div>
      <% end %>
    </section>

    <footer class="text-center mt-6 text-xs text-gray-400">
      Compartido vía <%= link_to "Tivo", root_path, class: "underline hover:text-gray-600" %>
    </footer>
  </div>
</div>
