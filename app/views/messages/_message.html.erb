<% is_new = local_assigns.fetch(:is_new, false) %>
<%= turbo_frame_tag dom_id(message) do %>
  <article class="group flex gap-3 px-4 py-2 hover:bg-gray-50 <%= 'bg-red-50/60 border-l-4 border-red-400 pl-3' if is_new %>" id="<%= dom_id(message, :wrapper) %>" data-message-id="<%= message.id %>" data-new-message="<%= is_new %>">
    <div class="flex-shrink-0 relative w-9 h-9">
      <% if message.user.avatar.attached? %>
        <%= image_tag message.user.avatar, class: "w-9 h-9 rounded-md object-cover" %>
      <% else %>
        <div class="w-9 h-9 rounded-md bg-indigo-100 text-indigo-700 flex items-center justify-center text-sm font-semibold">
          <%= message.user.initials %>
        </div>
      <% end %>
      <% if message.messageable.is_a?(Conversation) %>
        <%= render "shared/presence_dot", user: message.user, always_online: true %>
      <% end %>
    </div>

    <div class="min-w-0 flex-1">
      <div class="flex items-baseline gap-2">
        <span class="font-semibold text-gray-900 text-sm"><%= message.user.full_name.presence || message.user.email %></span>
        <time class="text-xs text-gray-500"><%= chat_message_time(message.created_at) %></time>
        <% if message.edited? %>
          <span class="text-xs text-gray-400">(editado)</span>
        <% end %>
      </div>

      <% if message.deleted? %>
        <div class="text-sm text-gray-400 italic">Mensaje eliminado</div>
      <% else %>
        <% if message.body.present? %>
          <div class="chat-body text-sm text-gray-800 break-words">
            <%= render_chat_message(message, project) %>
          </div>
        <% end %>

        <% if message.files.attached? %>
          <div class="mt-1 flex flex-wrap gap-2">
            <% message.files.each do |file| %>
              <% if file.image? %>
                <%= link_to rails_blob_path(file, disposition: "inline"),
                            class: "glightbox block rounded-lg overflow-hidden border border-gray-200 hover:opacity-90 transition-opacity max-w-xs cursor-zoom-in",
                            data: { gallery: "chat-#{message.messageable_type}-#{message.messageable_id}", type: "image", description: file.filename.to_s } do %>
                  <%= image_tag file.variant(resize_to_limit: [ 320, 320 ]), class: "block max-h-64 object-cover", alt: file.filename.to_s %>
                <% end %>
              <% else %>
                <%= link_to rails_blob_path(file, disposition: "attachment"), class: "inline-flex items-center gap-2 pl-2 pr-3 py-1.5 bg-gray-50 border border-gray-200 rounded-md text-xs text-gray-700 hover:bg-gray-100 max-w-xs" do %>
                  <span class="w-7 h-7 rounded bg-white border border-gray-200 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                  </span>
                  <span class="min-w-0">
                    <span class="block font-medium text-gray-800 truncate" title="<%= file.filename %>"><%= file.filename %></span>
                    <span class="block text-[10px] text-gray-500"><%= chat_attachment_size(file.byte_size) %></span>
                  </span>
                <% end %>
              <% end %>
            <% end %>
          </div>
        <% end %>
      <% end %>

      <% unless message.deleted? %>
        <%= render "messages/reactions", message: message, viewer: local_assigns[:viewer] %>
      <% end %>

      <% reply_count = message.replies.kept.count %>
      <% if reply_count.positive? && !message.thread? %>
        <%= link_to chat_thread_path(message, project), data: { turbo_frame: "thread_panel" }, class: "inline-flex items-center gap-1 mt-1 text-xs text-indigo-700 hover:underline" do %>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.86 9.86 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          <%= pluralize(reply_count, "respuesta", "respuestas") %>
        <% end %>
      <% end %>
    </div>

    <% viewer = local_assigns[:viewer] %>
    <div class="opacity-0 group-hover:opacity-100 flex items-start gap-1">
      <% unless message.deleted? %>
        <button type="button"
                data-reaction-trigger
                data-message-id="<%= message.id %>"
                data-action-url="<%= message_reactions_path(message_id: message.id) %>"
                class="text-gray-400 hover:text-indigo-700 p-1"
                title="Agregar reacción">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </button>
      <% end %>
      <% if !message.thread? && !message.deleted? %>
        <%= link_to chat_thread_path(message, project), data: { turbo_frame: "thread_panel" }, class: "text-gray-400 hover:text-indigo-700 p-1", title: "Responder en hilo" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.86 9.86 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        <% end %>
      <% end %>
      <% if viewer && message.user_id == viewer.id && !message.deleted? %>
        <% delete_url = message.messageable.is_a?(Channel) ? project_channel_message_path(project, message.messageable, message) : project_conversation_message_path(project, message.messageable, message) %>
        <%= button_to delete_url, method: :delete, form: { data: { turbo_confirm: "¿Eliminar este mensaje?" } }, class: "text-gray-400 hover:text-red-600 p-1" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"/></svg>
        <% end %>
      <% end %>
    </div>
  </article>
<% end %>
