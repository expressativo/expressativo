<%#
  locals:
    form_url    - URL del POST
    project     - Project para autocomplete de menciones
    placeholder - placeholder del textarea
    wrapper_class (opcional) - clases para el form
    submit_title  (opcional) - label accesible del botón enviar
%>
<%
  wrapper_class ||= "border-t border-gray-200 bg-white px-3 py-2"
  submit_title  ||= "Enviar mensaje (Enter)"
%>
<%= form_with url: form_url,
              scope: :message,
              data: { controller: "chat-form", "chat-form-members-url-value": project_chat_members_path(project), action: "turbo:submit-end->chat-form#reset", turbo_frame: "_top" },
              class: wrapper_class do |f| %>
  <div class="border border-gray-300 rounded-lg bg-white focus-within:border-indigo-500 focus-within:ring-1 focus-within:ring-indigo-500 transition-shadow">
    <div class="flex items-center gap-0.5 px-2 py-1 border-b border-gray-100 text-gray-500">
      <button type="button" title="Negrita (**texto**)"
              data-action="chat-form#applyMarkdown"
              data-chat-form-prefix-param="**" data-chat-form-suffix-param="**"
              data-chat-form-placeholder-param="texto"
              class="p-1.5 rounded hover:bg-gray-100 hover:text-gray-900 font-bold text-sm w-7 h-7 inline-flex items-center justify-center">B</button>
      <button type="button" title="Itálica (*texto*)"
              data-action="chat-form#applyMarkdown"
              data-chat-form-prefix-param="*" data-chat-form-suffix-param="*"
              data-chat-form-placeholder-param="texto"
              class="p-1.5 rounded hover:bg-gray-100 hover:text-gray-900 italic text-sm w-7 h-7 inline-flex items-center justify-center">I</button>
      <button type="button" title="Tachado (~~texto~~)"
              data-action="chat-form#applyMarkdown"
              data-chat-form-prefix-param="~~" data-chat-form-suffix-param="~~"
              data-chat-form-placeholder-param="texto"
              class="p-1.5 rounded hover:bg-gray-100 hover:text-gray-900 line-through text-sm w-7 h-7 inline-flex items-center justify-center">S</button>
      <span class="w-px h-4 bg-gray-200 mx-1"></span>
      <button type="button" title="Código en línea"
              data-action="chat-form#applyMarkdown"
              data-chat-form-prefix-param="`" data-chat-form-suffix-param="`"
              data-chat-form-placeholder-param="código"
              class="p-1.5 rounded hover:bg-gray-100 hover:text-gray-900 w-7 h-7 inline-flex items-center justify-center">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
      </button>
      <button type="button" title="Bloque de código"
              data-action="chat-form#applyCodeBlock"
              class="p-1.5 rounded hover:bg-gray-100 hover:text-gray-900 w-7 h-7 inline-flex items-center justify-center">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l-3 3 3 3m8-6l3 3-3 3M4 6h16a1 1 0 011 1v10a1 1 0 01-1 1H4a1 1 0 01-1-1V7a1 1 0 011-1z"/></svg>
      </button>
      <span class="w-px h-4 bg-gray-200 mx-1"></span>
      <button type="button" title="Lista con viñetas"
              data-action="chat-form#applyLinePrefix"
              data-chat-form-prefix-param="- "
              class="p-1.5 rounded hover:bg-gray-100 hover:text-gray-900 w-7 h-7 inline-flex items-center justify-center">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h.01M4 12h.01M4 18h.01M8 6h12M8 12h12M8 18h12"/></svg>
      </button>
      <button type="button" title="Lista numerada"
              data-action="chat-form#applyLinePrefix"
              data-chat-form-numbered-param="true"
              class="p-1.5 rounded hover:bg-gray-100 hover:text-gray-900 w-7 h-7 inline-flex items-center justify-center">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h12M7 12h12M7 17h12M3 7h.01M3 12h.01M3 17h.01"/></svg>
      </button>
    </div>

    <%= f.text_area :body, rows: 1, placeholder: placeholder,
                    class: "block w-full resize-none px-3 py-2 text-sm bg-transparent border-0 focus:outline-none focus:ring-0",
                    data: { "chat-form-target": "input" } %>

    <div data-chat-form-target="attachments" class="px-3 pb-2 flex flex-wrap gap-2 empty:hidden"></div>

    <div class="flex items-center justify-between px-2 py-1 border-t border-gray-100">
      <div class="flex items-center gap-1">
        <div class="relative">
          <button type="button" title="Insertar emoji"
                  data-action="chat-form#toggleEmojiPicker"
                  class="p-1.5 rounded hover:bg-gray-100 text-gray-500 hover:text-gray-900 w-8 h-8 inline-flex items-center justify-center">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </button>
          <div data-chat-form-target="emojiPicker" hidden class="absolute bottom-full left-0 mb-2 z-50"></div>
        </div>
        <button type="button" title="Adjuntar archivo"
                data-action="chat-form#openFileDialog"
                class="p-1.5 rounded hover:bg-gray-100 text-gray-500 hover:text-gray-900 w-8 h-8 inline-flex items-center justify-center">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
        </button>
        <input type="file" multiple class="hidden"
               data-chat-form-target="fileInput"
               data-action="change->chat-form#onFilesSelected" />
      </div>
      <button type="submit" title="<%= submit_title %>" aria-label="<%= submit_title %>"
              data-chat-form-target="submit"
              class="inline-flex items-center justify-center w-9 h-9 bg-indigo-600 hover:bg-indigo-700 text-white rounded-md transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
      </button>
    </div>
  </div>
<% end %>
