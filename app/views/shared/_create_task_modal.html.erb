<%# locals: (modal_title: "Crear tarea", show_selection_menu: false) %>

<% if show_selection_menu %>
  <div
    class="hidden fixed z-50 bg-white shadow-lg rounded-lg border border-gray-200 py-1 min-w-max"
    data-create-task-modal-target="menu"
  >
    <button
      type="button"
      class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 w-full text-left transition-colors"
      data-action="click->create-task-modal#openFromSelection"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 5v14M5 12h14"/>
      </svg>
      Crear tarea
    </button>
  </div>
<% end %>

<div
  class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50"
  data-create-task-modal-target="modal"
  data-action="click->create-task-modal#backdropClick"
>
  <div class="bg-white rounded-xl shadow-2xl p-6 max-w-md w-full mx-4">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-base font-semibold text-gray-900"><%= modal_title %></h3>
      <button
        type="button"
        class="text-gray-400 hover:text-gray-600 transition-colors"
        data-action="click->create-task-modal#closeModal"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <form data-action="submit->create-task-modal#createTask">
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Título de la tarea</label>
        <input
          type="text"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
          data-create-task-modal-target="taskTitle"
          placeholder="Título de la tarea"
          required
        >
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Lista de tareas</label>
        <select
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
          data-create-task-modal-target="todoSelect"
          required
        >
          <option value="">— Selecciona una lista —</option>
        </select>
      </div>
      <div class="mb-6">
        <button
          type="button"
          class="flex items-center gap-1 text-sm text-gray-500 hover:text-indigo-600 transition-colors mb-2"
          data-action="click->create-task-modal#toggleNotes"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-create-task-modal-target="notesToggleIcon">
            <path d="M12 5v14M5 12h14"/>
          </svg>
          Agregar notas <span class="text-gray-400 font-normal">(opcional)</span>
        </button>
        <div class="hidden" data-create-task-modal-target="notesField">
          <textarea
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none resize-none"
            data-create-task-modal-target="taskNotes"
            placeholder="Notas adicionales sobre la tarea..."
            rows="3"
          ></textarea>
        </div>
      </div>
      <div class="flex justify-end gap-3">
        <button
          type="button"
          class="button-outline"
          data-action="click->create-task-modal#closeModal"
        >
          Cancelar
        </button>
        <button
          type="submit"
          class="button"
        >
          Crear tarea
        </button>
      </div>
    </form>
  </div>
</div>
