<%
  # Locals:
  #   form       - form builder (required)
  #   field      - symbol, e.g. :notes, :body, :content (required)
  #   placeholder - String (optional)
  #   mentions   - Boolean, enables @ mentions (optional, default false)
  #   project_id - Integer (optional, for mentions)
  #   todo_id    - Integer (optional, for mentions)
  #   task_id    - Integer (optional, for mentions)
  #   wrapper_class - extra CSS classes on the outer wrapper (optional)

  placeholder   ||= "Escribe aquí..."
  mentions      ||= false
  project_id    ||= 0
  todo_id       ||= 0
  task_id       ||= 0
  wrapper_class ||= ""

  existing_html = form.object.send(field).body&.to_html || ""
%>

<div data-controller="lexical-editor"
     data-lexical-editor-placeholder-value="<%= placeholder %>"
     data-lexical-editor-mentions-value="<%= mentions %>"
     data-lexical-editor-project-id-value="<%= project_id %>"
     data-lexical-editor-todo-id-value="<%= todo_id %>"
     data-lexical-editor-task-id-value="<%= task_id %>"
     class="lexical-editor-wrapper <%= wrapper_class %>">

  <%= form.hidden_field field,
        value: existing_html,
        data: { lexical_editor_target: "input" } %>

  <div class="lexical-toolbar">
    <%# Undo / Redo %>
    <button type="button" class="lexical-toolbar-btn" data-format="undo"
            data-action="click->lexical-editor#undo" title="Deshacer">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v6h6"/><path d="M21 17a9 9 0 0 0-9-9 9 9 0 0 0-6 2.3L3 13"/></svg>
    </button>
    <button type="button" class="lexical-toolbar-btn" data-format="redo"
            data-action="click->lexical-editor#redo" title="Rehacer">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 7v6h-6"/><path d="M3 17a9 9 0 0 1 9-9 9 9 0 0 1 6 2.3L21 13"/></svg>
    </button>

    <span class="lexical-toolbar-divider"></span>

    <%# Headings %>
    <button type="button" class="lexical-toolbar-btn" data-format="h1"
            data-action="click->lexical-editor#formatH1" title="Título 1">H1</button>
    <button type="button" class="lexical-toolbar-btn" data-format="h2"
            data-action="click->lexical-editor#formatH2" title="Título 2">H2</button>
    <button type="button" class="lexical-toolbar-btn" data-format="h3"
            data-action="click->lexical-editor#formatH3" title="Título 3">H3</button>

    <span class="lexical-toolbar-divider"></span>

    <%# Inline formats %>
    <button type="button" class="lexical-toolbar-btn" data-format="bold"
            data-action="click->lexical-editor#formatBold" title="Negrita">
      <strong>B</strong>
    </button>
    <button type="button" class="lexical-toolbar-btn" data-format="italic"
            data-action="click->lexical-editor#formatItalic" title="Cursiva">
      <em>I</em>
    </button>
    <button type="button" class="lexical-toolbar-btn" data-format="underline"
            data-action="click->lexical-editor#formatUnderline" title="Subrayado">
      <span style="text-decoration:underline">U</span>
    </button>
    <button type="button" class="lexical-toolbar-btn" data-format="strikethrough"
            data-action="click->lexical-editor#formatStrikethrough" title="Tachado">
      <span style="text-decoration:line-through">S</span>
    </button>

    <span class="lexical-toolbar-divider"></span>

    <%# Lists %>
    <button type="button" class="lexical-toolbar-btn" data-format="bullet-list"
            data-action="click->lexical-editor#formatBulletList" title="Lista con viñetas">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="9" x2="21" y1="6" y2="6"/><line x1="9" x2="21" y1="12" y2="12"/><line x1="9" x2="21" y1="18" y2="18"/><circle cx="4" cy="6" r="1" fill="currentColor" stroke="none"/><circle cx="4" cy="12" r="1" fill="currentColor" stroke="none"/><circle cx="4" cy="18" r="1" fill="currentColor" stroke="none"/></svg>
    </button>
    <button type="button" class="lexical-toolbar-btn" data-format="ordered-list"
            data-action="click->lexical-editor#formatOrderedList" title="Lista numerada">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="10" x2="21" y1="6" y2="6"/><line x1="10" x2="21" y1="12" y2="12"/><line x1="10" x2="21" y1="18" y2="18"/><path d="M4 6h1v4"/><path d="M4 10h2"/><path d="M6 18H4c0-1 2-2 2-3s-1-1.5-2-1"/></svg>
    </button>
    <button type="button" class="lexical-toolbar-btn" data-format="quote"
            data-action="click->lexical-editor#formatQuote" title="Cita">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>
    </button>

    <span class="lexical-toolbar-divider"></span>

    <%# Code %>
    <button type="button" class="lexical-toolbar-btn font-mono text-xs" data-format="inline-code"
            data-action="click->lexical-editor#formatInlineCode" title="Código inline">&lt;/&gt;</button>
    <button type="button" class="lexical-toolbar-btn" data-format="code-block"
            data-action="click->lexical-editor#formatCodeBlock" title="Bloque de código">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
    </button>
  </div>

  <div class="lexical-editor"
       data-lexical-editor-target="editor"
       data-placeholder="<%= placeholder %>">
  </div>
</div>
