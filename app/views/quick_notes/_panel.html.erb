<div class="flex flex-col max-h-[480px]">
  <!-- Header -->
  <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
    <div class="flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-amber-500">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14,2 14,8 20,8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
        <polyline points="10,9 9,9 8,9"/>
      </svg>
      <span class="text-sm font-semibold text-gray-800">Notas rápidas</span>
    </div>
    <span class="text-xs text-gray-400"><%= quick_notes.size %> nota<%= "s" if quick_notes.size != 1 %></span>
  </div>

  <!-- Lista de notas -->
  <div id="quick_notes_list" class="flex-1 overflow-y-auto px-3 py-2 space-y-2">
    <% if quick_notes.any? %>
      <%= render partial: "quick_notes/quick_note", collection: quick_notes, as: :note %>
    <% else %>
      <div class="text-center py-6 text-gray-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto mb-2 text-gray-300">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14,2 14,8 20,8"/>
        </svg>
        <p class="text-xs">Sin notas aún</p>
      </div>
    <% end %>
  </div>

  <!-- Form nueva nota -->
  <div class="border-t border-gray-100 px-3 py-3">
    <%= render "quick_notes/form", note: new_note %>
  </div>
</div>
