<%= turbo_frame_tag "thread_panel" do %>
  <aside class="fixed inset-y-0 right-0 w-96 bg-white border-l border-gray-200 shadow-lg z-40 flex flex-col" data-controller="thread-panel">
    <header class="px-4 py-3 border-b border-gray-200 flex items-center justify-between flex-shrink-0">
      <div>
        <h2 class="font-semibold text-gray-900 text-sm">Hilo</h2>
        <p class="text-xs text-gray-500">#<%= @channel.name %></p>
      </div>
      <%= link_to project_channel_path(@project, @channel), data: { turbo_frame: "thread_panel", turbo_action: "replace" }, class: "text-gray-400 hover:text-gray-600 p-1", aria: { label: "Cerrar hilo" } do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      <% end %>
    </header>

    <div class="flex-1 overflow-y-auto" id="<%= dom_id(@parent, :replies) %>">
      <div class="border-b border-gray-200">
        <%= render "messages/message", message: @parent, project: @project, viewer: current_user %>
      </div>

      <% if @replies.any? %>
        <%= render partial: "messages/message", collection: @replies, locals: { project: @project, viewer: current_user } %>
      <% else %>
        <p class="text-center text-xs text-gray-400 py-6">Sin respuestas todavía.</p>
      <% end %>
    </div>

    <%= form_with url: project_channel_message_replies_path(@project, @channel, @parent),
                  scope: :message,
                  data: { controller: "chat-form", "chat-form-members-url-value": project_chat_members_path(@project), action: "turbo:submit-end->chat-form#reset" },
                  class: "border-t border-gray-200 px-3 py-2 flex-shrink-0" do |f| %>
      <div class="flex items-end gap-2">
        <%= f.text_area :body, rows: 1, placeholder: "Responder al hilo…", class: "flex-1 resize-none rounded-md border border-gray-300 px-3 py-2 text-sm", data: { "chat-form-target": "input" } %>
        <%= f.submit "Responder", class: "bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-3 py-2 rounded-md", data: { "chat-form-target": "submit" } %>
      </div>
    <% end %>
  </aside>
<% end %>
