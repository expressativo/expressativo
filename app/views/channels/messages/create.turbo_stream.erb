<%= turbo_stream.append dom_id(@channel, :messages) do %>
  <%= render "messages/message", message: @message, project: @project, viewer: current_user %>
<% end %>
<%= turbo_stream.replace "message_form" do %>
  <%= render "messages/form", message: @channel.messages.build, messageable: @channel, project: @project %>
<% end %>
