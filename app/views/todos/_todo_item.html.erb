<% tasks.each do |task| %>
  <%= turbo_frame_tag dom_id(task), data: { task_id: task.id } do %>
    <li class="flex items-center gap-2 group/task">
      <% unless task.completed? %>
        <button type="button"
                class="task-drag-handle cursor-grab text-gray-300 hover:text-gray-500 opacity-0 group-hover/task:opacity-100 transition"
                aria-label="Arrastrar para reordenar">
          <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
            <circle cx="7" cy="5" r="1.5"/><circle cx="13" cy="5" r="1.5"/>
            <circle cx="7" cy="10" r="1.5"/><circle cx="13" cy="10" r="1.5"/>
            <circle cx="7" cy="15" r="1.5"/><circle cx="13" cy="15" r="1.5"/>
          </svg>
        </button>
      <% end %>
      <%= form_with class: "flex items-center", model: [@project, todo, task], method: :patch, data: { turbo_frame: dom_id(todo) } do |f| %>
        <%= f.check_box :completed, {
              class: "w-4 h-4 text-purple-600 focus:ring-purple-500 border-gray-300 rounded cursor-pointer",
              onchange: "this.form.requestSubmit()"
            } %>
      <% end %>
      <%= link_to project_todo_task_path(@project, todo, task),
            class: "flex-1 min-w-0 text-sm truncate transition #{task.completed? ? 'text-gray-400 line-through' : 'text-gray-700 hover:text-purple-600'}",
            data: { turbo_frame: "_top" } do %>
        <%= task.title %>
      <% end %>
    </li>
  <% end %>
<% end %>
