<div class="max-w-7xl mx-auto py-4">
  <nav class="flex items-center text-sm text-gray-500 mb-3 flex-wrap" aria-label="Breadcrumb">
    <%= link_to "Proyectos", projects_path, class: "hover:text-purple-600 transition-colors" %>
    <svg class="w-4 h-4 mx-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
    <%= link_to @project.title, project_path(@project), class: "hover:text-purple-600 transition-colors truncate" %>
    <svg class="w-4 h-4 mx-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
    <%= link_to "To-dos", project_todos_path(@project), class: "hover:text-purple-600 transition-colors" %>
    <svg class="w-4 h-4 mx-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
    <%= link_to @todo.name, project_todo_path(@project, @todo), class: "hover:text-purple-600 transition-colors truncate" %>
    <svg class="w-4 h-4 mx-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
    <span class="text-gray-800 font-medium">Completadas</span>
  </nav>

  <%= render 'projects/project_header', project: @project %>

  <%= render 'projects/tabs', project: @project, active: :todos %>

  <section class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
    <header class="px-6 py-4 border-b border-gray-200 flex items-center justify-between gap-3 flex-wrap">
      <div class="flex items-center gap-2 min-w-0">
        <span class="w-2.5 h-2.5 rounded-full bg-green-500 flex-shrink-0"></span>
        <h2 class="text-lg font-semibold text-gray-900 truncate">
          Tareas completadas <span class="text-gray-400 font-normal">·</span> <span class="text-gray-600 font-normal"><%= @todo.name %></span>
        </h2>
      </div>
      <span class="text-xs font-medium text-gray-600 bg-gray-100 rounded-full px-2 py-0.5 flex-shrink-0">
        <%= @completed_tasks.count %> <%= "tarea".pluralize(@completed_tasks.count) %>
      </span>
    </header>

    <div class="p-6">
      <% if @completed_tasks.any? %>
        <ul class="space-y-1.5">
          <%= render 'todos/todo_item', tasks: @completed_tasks, todo: @todo %>
        </ul>
      <% else %>
        <p class="text-sm text-gray-500 italic">Aún no hay tareas completadas en esta lista.</p>
      <% end %>
    </div>
  </section>
</div>
