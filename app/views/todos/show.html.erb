<div class="max-w-7xl mx-auto py-4">
  <nav class="flex items-center text-sm text-gray-500 mb-3 flex-wrap" aria-label="Breadcrumb">
    <%= link_to "Proyectos", projects_path, class: "hover:text-purple-600 transition-colors" %>
    <svg class="w-4 h-4 mx-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
    <%= link_to @project.title, project_path(@project), class: "hover:text-purple-600 transition-colors truncate" %>
    <svg class="w-4 h-4 mx-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
    <%= link_to "To-dos", project_todos_path(@project), class: "hover:text-purple-600 transition-colors" %>
    <svg class="w-4 h-4 mx-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
    <span class="text-gray-800 font-medium truncate"><%= @todo.name %></span>
  </nav>

  <%= render 'projects/project_header', project: @project %>

  <%= render 'projects/tabs', project: @project, active: :todos %>

  <%= turbo_frame_tag dom_id(@todo) do %>
    <% completed = @todo.tasks.where(done: true).count %>
    <% total = @todo.tasks.count %>
    <% pct = total.positive? ? (completed * 100.0 / total).round : 0 %>
    <section class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
      <header class="px-6 py-4 border-b border-gray-200">
        <div class="flex items-start justify-between gap-3 mb-3">
          <div class="flex items-center gap-2 min-w-0">
            <span class="w-3 h-3 rounded-full bg-green-500 flex-shrink-0"></span>
            <%= link_to @todo.name, edit_project_todo_path(@project, @todo),
                  data: { turbo_frame: "modal", turbo: false },
                  class: "text-lg font-semibold text-gray-900 hover:text-purple-600 truncate" %>
          </div>
          <span class="text-xs font-medium text-gray-600 bg-gray-100 rounded-full px-2 py-0.5 flex-shrink-0">
            <%= completed %>/<%= total %> completadas
          </span>
        </div>
        <div class="w-full h-1.5 bg-gray-100 rounded-full overflow-hidden">
          <div class="h-1.5 bg-green-500 rounded-full transition-all" style="width: <%= pct %>%"></div>
        </div>
      </header>

      <div class="p-6">
        <%= turbo_frame_tag "#{dom_id(@todo)}_tasks" do %>
          <% if total.zero? %>
            <p class="text-sm text-gray-500 italic mb-3">Aún no hay tareas en esta lista.</p>
          <% else %>
            <ul class="space-y-1.5 mb-3">
              <%= render 'todos/todo_item', tasks: @todo.tasks.where(done: false), todo: @todo %>
              <%= render 'todos/todo_item', tasks: @todo.tasks.order(updated_at: :desc).where(done: true).limit(5), todo: @todo %>
              <% if completed > 5 %>
                <li class="pl-6">
                  <%= link_to "Ver completadas (#{completed})", completed_tasks_project_todo_path(@project, @todo),
                        class: "text-xs font-medium text-purple-600 hover:text-purple-700",
                        data: { turbo_frame: "_top" } %>
                </li>
              <% end %>
            </ul>
          <% end %>
        <% end %>

        <%= turbo_frame_tag "#{dom_id(@todo)}_task_form" do %>
          <div class="pt-3 border-t border-gray-100">
            <%= link_to new_project_todo_task_path(@project, @todo),
                  data: { turbo_frame: "#{dom_id(@todo)}_task_form" },
                  class: "inline-flex items-center gap-1.5 text-sm font-medium text-gray-600 hover:text-purple-600 transition" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              Agregar tarea
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
