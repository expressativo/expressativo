<div class="p-6">
  <div class="<%= @view_type == 'grid' ? 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4' : 'space-y-3' %>">
    <% @todos.each do |todo| %>
      <%= turbo_frame_tag dom_id(todo) do %>
        <% completed = todo.tasks.done.count %>
        <% total = todo.tasks.count %>
        <% pct = total.positive? ? (completed * 100.0 / total).round : 0 %>
        <article class="bg-white border border-gray-200 hover:border-purple-300 rounded-xl p-4 transition group">
          <header class="flex items-start justify-between gap-3 mb-3">
            <div class="flex items-center gap-2 min-w-0 flex-1">
              <span class="w-2.5 h-2.5 rounded-full bg-green-500 flex-shrink-0"></span>
              <%= link_to todo.name, project_todo_path(@project, todo),
                    data: { turbo_frame: "modal", turbo: false },
                    class: "text-sm font-semibold text-gray-900 hover:text-purple-600 truncate" %>
            </div>
            <span class="text-xs font-medium text-gray-600 bg-gray-100 rounded-full px-2 py-0.5 flex-shrink-0">
              <%= completed %>/<%= total %>
            </span>
          </header>

          <div class="w-full h-1 bg-gray-100 rounded-full mb-3 overflow-hidden">
            <div class="h-1 bg-green-500 rounded-full transition-all" style="width: <%= pct %>%"></div>
          </div>

          <%= turbo_frame_tag "#{dom_id(todo)}_tasks" do %>
            <ul class="space-y-1.5"
                data-controller="task-sortable"
                data-task-sortable-url-template-value="<%= update_position_project_todo_task_path(@project, todo, ':id') %>">
              <%= render 'todos/todo_item', tasks: todo.tasks.not_done.list_ordered, todo: todo %>
            </ul>
            <ul class="space-y-1.5">
              <%= render 'todos/todo_item', tasks: todo.tasks.done.order(updated_at: :desc).limit(5), todo: todo %>
              <% if completed > 5 %>
                <li class="pl-6">
                  <%= link_to "Ver completadas (#{completed})", completed_tasks_project_todo_path(@project, todo),
                        class: "text-xs font-medium text-purple-600 hover:text-purple-700",
                        data: { turbo_frame: "_top" } %>
                </li>
              <% end %>
            </ul>
          <% end %>

          <%= turbo_frame_tag "#{dom_id(todo)}_task_form" do %>
            <footer class="mt-3 pt-3 border-t border-gray-100">
              <%= link_to new_project_todo_task_path(@project, todo),
                    data: { turbo_frame: "#{dom_id(todo)}_task_form" },
                    class: "inline-flex items-center gap-1 text-sm font-medium text-gray-500 hover:text-purple-600 transition" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Agregar tarea
              <% end %>
            </footer>
          <% end %>
        </article>
      <% end %>
    <% end %>
  </div>
</div>
