<!DOCTYPE html>
<html lang="es">
  <head>
    <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
    <meta name="color-scheme" content="light only">
    <meta name="supported-color-schemes" content="light only">
  </head>
  <body style="margin: 0; padding: 24px; background-color: #f3f4f6; font-family: Arial, Helvetica, sans-serif; line-height: 1.6; color: #1f2937;">
    <table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center">
          <table role="presentation" width="600" border="0" cellpadding="0" cellspacing="0" style="max-width: 600px; width: 100%; background-color: #ffffff; border-radius: 12px; overflow: hidden; border: 1px solid #e5e7eb;">
            <tr>
              <td style="background-color: #4F46E5; padding: 24px;">
                <h2 style="margin: 0; color: #ffffff; font-size: 20px; font-weight: 700;">Nueva tarea asignada en <%= @project.title %></h2>
              </td>
            </tr>
            <tr>
              <td style="padding: 24px; background-color: #f9fafb;">
                <p style="margin: 0 0 12px;">Hola <%= @task_assignment.user.full_name.presence || @task_assignment.user.email %>,</p>

                <p style="margin: 0 0 12px;">
                  <strong><%= @assigned_by.full_name.presence || @assigned_by.email %></strong>
                  te ha asignado la tarea
                  <strong>"<%= @task.title %>"</strong>.
                </p>

                <% if @task.notes.present? || @task.due_date.present? %>
                  <div style="background-color: #ffffff; padding: 16px; border-left: 4px solid #4F46E5; margin: 16px 0;">
                    <% if @task.notes.present? %>
                      <div class="trix-content" style="margin: 0 0 8px;"><%= @task.notes %></div>
                    <% end %>
                    <% if @task.due_date.present? %>
                      <p style="margin: 0;"><strong>Fecha límite:</strong> <%= l(@task.due_date, format: :long) %></p>
                    <% end %>
                  </div>
                <% end %>

                <%= render "shared/mail_button",
                    url: project_todo_task_url(@project, @task.todo, @task),
                    label: "Ver tarea" %>

                <p style="text-align: center; color: #6b7280; font-size: 12px; margin: 24px 0 0;">
                  Este es un correo automático de Expressativo.<br>
                  No respondas a este mensaje.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
