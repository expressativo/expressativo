<section class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
  <%= link_to project_todos_path(@project), class: "group bg-white border border-gray-200 rounded-xl p-3 hover:border-purple-300 hover:shadow-sm transition-all" do %>
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 rounded-lg bg-purple-50 flex items-center justify-center text-purple-600 flex-shrink-0">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
      </div>
      <div class="min-w-0 flex-1">
        <div class="text-xl font-bold text-gray-900 leading-tight"><%= @tasks_pending %></div>
        <div class="text-xs text-gray-500">Tareas pendientes</div>
      </div>
      <span class="text-xs text-gray-300 group-hover:text-purple-500 transition-colors">→</span>
    </div>
  <% end %>

  <div class="bg-white border border-gray-200 rounded-xl p-3">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 rounded-lg bg-green-50 flex items-center justify-center text-green-600 flex-shrink-0">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <div class="min-w-0 flex-1">
        <div class="text-xl font-bold text-gray-900 leading-tight"><%= @tasks_completed %><span class="text-sm font-normal text-gray-400">/<%= @tasks_total %></span></div>
        <div class="text-xs text-gray-500">Tareas completadas</div>
      </div>
      <span class="text-xs font-medium text-green-600 flex-shrink-0"><%= @completion_pct %>%</span>
    </div>
    <div class="w-full bg-gray-100 rounded-full h-1 mt-2.5">
      <div class="bg-green-500 h-1 rounded-full transition-all" style="width: <%= @completion_pct %>%"></div>
    </div>
  </div>

  <%= link_to project_documents_path(@project), class: "group bg-white border border-gray-200 rounded-xl p-3 hover:border-blue-300 hover:shadow-sm transition-all" do %>
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600 flex-shrink-0">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
      </div>
      <div class="min-w-0 flex-1">
        <div class="text-xl font-bold text-gray-900 leading-tight"><%= @documents_count %></div>
        <div class="text-xs text-gray-500">Documentos</div>
      </div>
      <span class="text-xs text-gray-300 group-hover:text-blue-500 transition-colors">→</span>
    </div>
  <% end %>

  <%= link_to project_boards_path(@project), class: "group bg-white border border-gray-200 rounded-xl p-3 hover:border-amber-300 hover:shadow-sm transition-all" do %>
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 rounded-lg bg-amber-50 flex items-center justify-center text-amber-600 flex-shrink-0">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v6a2 2 0 01-2 2h-2a2 2 0 01-2-2V6z"/>
        </svg>
      </div>
      <div class="min-w-0 flex-1">
        <div class="text-xl font-bold text-gray-900 leading-tight"><%= @boards_count %></div>
        <div class="text-xs text-gray-500">Tableros</div>
      </div>
      <span class="text-xs text-gray-300 group-hover:text-amber-500 transition-colors">→</span>
    </div>
  <% end %>
</section>
