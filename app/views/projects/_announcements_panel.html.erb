<section class="bg-white border border-gray-200 rounded-2xl">
  <header class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
    <div class="flex items-center gap-2">
      <svg class="w-5 h-5 text-rose-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
      </svg>
      <h2 class="text-base font-semibold text-gray-900">Anuncios</h2>
    </div>
    <%= link_to "Nuevo", new_project_announcement_path(@project), class: "text-xs font-medium text-purple-600 hover:text-purple-700" %>
  </header>

  <% if @recent_announcements.any? %>
    <ul class="divide-y divide-gray-100">
      <% @recent_announcements.each do |a| %>
        <li>
          <%= link_to project_announcement_path(@project, a), class: "block px-5 py-3 hover:bg-gray-50 transition-colors" do %>
            <div class="text-sm text-gray-900 line-clamp-2"><%= truncate(a.content.to_s, length: 120) %></div>
            <div class="text-xs text-gray-400 mt-1"><%= time_ago_in_words(a.created_at) %> atrás</div>
          <% end %>
        </li>
      <% end %>
    </ul>
    <div class="px-5 py-3 border-t border-gray-100 text-center">
      <%= link_to "Ver todos los anuncios", project_announcements_path(@project), class: "text-xs font-medium text-purple-600 hover:text-purple-700" %>
    </div>
  <% else %>
    <div class="px-5 py-10 text-center">
      <svg class="w-10 h-10 mx-auto text-gray-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
      </svg>
      <p class="text-sm text-gray-500 mb-2">Sin anuncios.</p>
      <%= link_to "Crear anuncio", new_project_announcement_path(@project), class: "inline-block text-xs font-medium text-purple-600 hover:text-purple-700" %>
    </div>
  <% end %>
</section>
