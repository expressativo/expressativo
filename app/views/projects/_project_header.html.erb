<section class="bg-white border border-gray-200 rounded-2xl p-6 mb-4">
  <div class="flex items-start justify-between gap-4">
    <div class="flex items-start gap-4 min-w-0">
      <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-purple-500 to-indigo-600 flex items-center justify-center text-white text-xl font-bold flex-shrink-0">
        <%= project.title.to_s.first(2).upcase %>
      </div>
      <div class="min-w-0">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-xs font-medium text-gray-500 uppercase tracking-wider">Proyecto</span>
          <% if project.archived %>
            <span class="text-xs font-medium px-2 py-0.5 bg-amber-100 text-amber-700 rounded-full">Archivado</span>
          <% end %>
        </div>
        <h1 class="text-2xl md:text-3xl font-bold text-gray-900 truncate">
          <%= project.title %>
        </h1>
        <% if project.description.present? %>
          <p class="text-gray-600 mt-2 max-w-3xl"><%= project.description %></p>
        <% else %>
          <p class="text-gray-400 italic mt-2 text-sm">
            <%= link_to "Añade una descripción al proyecto", edit_project_path(project), class: "hover:text-purple-600 underline" %>
          </p>
        <% end %>
      </div>
    </div>

    <div class="flex items-center gap-2 flex-shrink-0">
      <%= render 'projects/option_dropdown', project: project %>
    </div>
  </div>

  <div class="flex items-center gap-4 mt-5 pt-4 border-t border-gray-100 flex-wrap">
    <div class="flex items-center gap-2">
      <span class="text-xs text-gray-500 font-medium">Equipo:</span>
      <div class="flex -space-x-2">
        <% if project.owner.present? %>
          <span title="<%= project.owner.first_name %> <%= project.owner.last_name %> (Owner)" class="ring-2 ring-white rounded-full">
            <%= user_avatar(project.owner) %>
          </span>
        <% end %>
        <% project.members.limit(5).each do |member| %>
          <span title="<%= member.first_name %> <%= member.last_name %>" class="ring-2 ring-white rounded-full">
            <%= user_avatar(member) %>
          </span>
        <% end %>
        <% extra = project.members.count - 5 %>
        <% if extra > 0 %>
          <div class="w-8 h-8 rounded-full bg-gray-200 ring-2 ring-white flex items-center justify-center text-xs font-medium text-gray-700">
            +<%= extra %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="h-4 w-px bg-gray-200"></div>

    <div class="flex items-center gap-1.5 text-xs text-gray-500">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      Creado <%= l(project.created_at.to_date, format: :long) rescue project.created_at.strftime("%d/%m/%Y") %>
    </div>

    <% if project.has_calendar %>
      <div class="h-4 w-px bg-gray-200"></div>
      <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium bg-blue-50 text-blue-700 rounded">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
          <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
          <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
        </svg>
        Calendario activo
      </span>
    <% end %>
  </div>
</section>
