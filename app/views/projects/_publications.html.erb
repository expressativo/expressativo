<%
  today = Date.today
  current_month_publications = @project.publications.for_month(today.year, today.month).order(:publication_date)
%>
<section class="bg-white border border-gray-200 rounded-2xl">
  <header class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
    <div class="flex items-center gap-2">
      <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      <h2 class="text-base font-semibold text-gray-900">Publicaciones</h2>
      <span class="text-xs font-medium text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full"><%= current_month_publications.count %></span>
    </div>
    <%= link_to "Calendario", project_publications_path(@project), class: "text-xs font-medium text-purple-600 hover:text-purple-700" %>
  </header>

  <% if current_month_publications.any? %>
    <ul class="divide-y divide-gray-100">
      <% current_month_publications.limit(4).each do |publication| %>
        <li class="px-5 py-3 flex items-start gap-3">
          <div class="flex-shrink-0 w-10 text-center">
            <div class="text-xs uppercase text-gray-500 font-medium leading-none mt-0.5"><%= publication.publication_date.strftime('%b') %></div>
            <div class="text-lg font-bold text-gray-900 leading-tight"><%= publication.publication_date.strftime('%d') %></div>
          </div>
          <div class="min-w-0 flex-1">
            <div class="text-sm font-medium text-gray-900 truncate"><%= publication.title %></div>
            <% if publication.task.present? %>
              <div class="inline-flex items-center gap-1 text-xs text-green-600 mt-0.5">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Tarea creada
              </div>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>
    <% if current_month_publications.count > 4 %>
      <div class="px-5 py-3 border-t border-gray-100 text-center">
        <%= link_to "+ #{current_month_publications.count - 4} más este mes", project_publications_path(@project), class: "text-xs font-medium text-purple-600 hover:text-purple-700" %>
      </div>
    <% end %>
  <% else %>
    <div class="px-5 py-10 text-center">
      <svg class="w-10 h-10 mx-auto text-gray-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      <p class="text-sm text-gray-500 mb-2">Sin publicaciones este mes.</p>
      <%= link_to "Ver calendario", project_publications_path(@project), class: "inline-block text-xs font-medium text-purple-600 hover:text-purple-700" %>
    </div>
  <% end %>
</section>
