<div class="max-w-7xl mx-auto py-4">
  <nav class="flex items-center text-sm text-gray-500 mb-3" aria-label="Breadcrumb">
    <%= link_to "Proyectos", projects_path, class: "hover:text-purple-600 transition-colors" %>
    <svg class="w-4 h-4 mx-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
    <span class="text-gray-800 font-medium truncate"><%= @project.title %></span>
  </nav>

  <%= render 'project_header', project: @project %>

  <%= render 'tabs', project: @project, active: :summary %>

  <%= render 'summary_stats' %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mt-4">
    <div class="lg:col-span-2 space-y-4">
      <%= render 'upcoming_tasks' %>
      <%= render 'boards' %>
      <%= render 'docs' %>
    </div>

    <div class="space-y-4">
      <%= render 'team_panel', project: @project %>
      <%= render 'recent_activity' %>
      <% if @project.has_calendar %>
        <%= render 'publications' %>
      <% end %>
      <%= render 'announcements_panel' %>
    </div>
  </div>
</div>
