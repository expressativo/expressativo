<%
  active ||= :summary
  nav_items = [
    { id: :summary,    label: "Resumen",    href: project_path(project),
      icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>' },
    { id: :boards,     label: "Tableros",   href: project_boards_path(project),
      icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v6a2 2 0 01-2 2h-2a2 2 0 01-2-2V6z"/>' },
    { id: :todos,      label: "To-dos",     href: project_todos_path(project),
      icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>' },
    { id: :documents,  label: "Documentos", href: project_documents_path(project),
      icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>' }
  ]
  if project.has_calendar
    nav_items << { id: :publications, label: "Calendario", href: project_publications_path(project),
                   icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>' }
  end
  nav_items << { id: :announcements, label: "Anuncios", href: project_announcements_path(project),
                 icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>' }
  if project.has_chat
    nav_items << { id: :chat, label: "Chat", href: project_channels_path(project),
                 icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>' }
  end
  nav_items << { id: :members, label: "Miembros", href: project_members_path(project),
                 icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>' }
%>
<aside
  data-controller="project-sidebar"
  data-project-sidebar-storage-key-value="project_sidebar_collapsed"
  class="bg-white border border-gray-200 rounded-2xl flex-shrink-0 self-start sticky top-4 transition-[width] duration-200 ease-out w-60 data-[collapsed=true]:w-16">

  <div class="px-3 pt-3 pb-1 flex items-center justify-between gap-2 min-w-0">
    <%= link_to projects_path, class: "inline-flex items-center gap-1 text-xs text-gray-500 hover:text-purple-600 transition-colors min-w-0" do %>
      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      <span class="truncate" data-project-sidebar-target="label">Mis proyectos</span>
    <% end %>
    <button
      type="button"
      data-action="click->project-sidebar#toggle"
      class="p-1 rounded-md text-gray-400 hover:text-gray-700 hover:bg-gray-100 transition-colors flex-shrink-0"
      title="Contraer/expandir">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" data-project-sidebar-target="toggleIcon">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"/>
      </svg>
    </button>
  </div>

  <div class="px-3 pb-4 pt-2 border-b border-gray-100 flex items-center gap-2 min-w-0">
    <%= link_to project_path(project), class: "w-9 h-9 rounded-lg bg-gradient-to-br from-purple-500 to-indigo-600 flex items-center justify-center text-white text-sm font-bold flex-shrink-0", title: project.title do %>
      <%= project.title.to_s.first(2).upcase %>
    <% end %>
    <div class="min-w-0 flex-1" data-project-sidebar-target="label">
      <%= link_to project.title, project_path(project), class: "block text-sm font-semibold text-gray-900 truncate hover:text-purple-600 transition-colors", title: project.title %>
      <% if project.archived %>
        <span class="text-[10px] font-medium px-1.5 py-0.5 bg-amber-100 text-amber-700 rounded">Archivado</span>
      <% end %>
    </div>
  </div>

  <nav class="p-2 space-y-0.5">
    <% nav_items.each do |item| %>
      <% is_active = item[:id] == active %>
      <%= link_to item[:href],
            title: item[:label],
            class: "group flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors #{is_active ? 'bg-purple-50 text-purple-700' : 'text-gray-700 hover:bg-gray-50 hover:text-gray-900'}" do %>
        <svg class="w-5 h-5 flex-shrink-0 <%= 'text-purple-600' if is_active %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><%= item[:icon].html_safe %></svg>
        <span class="truncate" data-project-sidebar-target="label"><%= item[:label] %></span>
      <% end %>
    <% end %>
  </nav>
</aside>
