<%= simple_form_for project, html: { class: "p-6" } do |f| %>
  <% if project.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-5 text-sm text-red-700">
      <p class="font-medium mb-1">
        Hay <%= pluralize(project.errors.count, "error") %> que corregir:
      </p>
      <ul class="list-disc list-inside space-y-0.5">
        <% project.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.input :title,
        label: "Título",
        placeholder: "Ej. Lanzamiento Q4",
        hint: "Un nombre claro y corto para identificar el proyecto." %>

  <%= f.input :description,
        as: :text,
        label: "Descripción",
        placeholder: "¿De qué trata este proyecto? Objetivos, alcance, etc.",
        input_html: { rows: 4 } %>

  <%= f.input :has_calendar,
        as: :boolean,
        label: "Habilitar calendario",
        hint: "Permite programar publicaciones y eventos en este proyecto." %>

  <div class="flex items-center justify-end gap-2 pt-5 mt-2 border-t border-gray-100">
    <%= link_to "Cancelar",
          project.persisted? ? project_path(project) : projects_path,
          class: "inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 hover:bg-gray-50 rounded-md transition" %>

    <%= f.button :submit,
          project.persisted? ? "Guardar cambios" : "Crear proyecto",
          class: "inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-white bg-purple-600 hover:bg-purple-700 rounded-md transition shadow-sm",
          data: { turbo_submits_with: "Guardando..." } %>
  </div>
<% end %>
