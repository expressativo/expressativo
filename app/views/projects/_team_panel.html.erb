<section class="bg-white border border-gray-200 rounded-2xl">
  <header class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
    <div class="flex items-center gap-2">
      <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
      </svg>
      <h2 class="text-base font-semibold text-gray-900">Equipo</h2>
    </div>
    <%= link_to "Gestionar", project_members_path(project), class: "text-xs font-medium text-purple-600 hover:text-purple-700" %>
  </header>

  <ul class="divide-y divide-gray-100">
    <% if project.owner.present? %>
      <li class="flex items-center gap-3 px-5 py-3">
        <%= user_avatar(project.owner) %>
        <div class="min-w-0 flex-1">
          <div class="text-sm font-medium text-gray-900 truncate"><%= project.owner.first_name %> <%= project.owner.last_name %></div>
          <div class="text-xs text-gray-500 truncate"><%= project.owner.email %></div>
        </div>
        <span class="text-xs font-medium px-2 py-0.5 bg-purple-50 text-purple-700 rounded">Owner</span>
      </li>
    <% end %>
    <% project.members.limit(5).each do |member| %>
      <li class="flex items-center gap-3 px-5 py-3">
        <%= user_avatar(member) %>
        <div class="min-w-0 flex-1">
          <div class="text-sm font-medium text-gray-900 truncate"><%= member.first_name %> <%= member.last_name %></div>
          <div class="text-xs text-gray-500 truncate"><%= member.email %></div>
        </div>
        <span class="text-xs text-gray-500">Miembro</span>
      </li>
    <% end %>
  </ul>

  <% extra = project.members.count - 5 %>
  <% if extra > 0 %>
    <div class="px-5 py-3 border-t border-gray-100 text-center">
      <%= link_to "Ver #{extra} miembro(s) más", project_members_path(project), class: "text-xs font-medium text-purple-600 hover:text-purple-700" %>
    </div>
  <% end %>
</section>
