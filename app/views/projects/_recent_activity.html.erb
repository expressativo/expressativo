<section class="bg-white border border-gray-200 rounded-2xl">
  <header class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
    <div class="flex items-center gap-2">
      <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
      </svg>
      <h2 class="text-base font-semibold text-gray-900">Actividad reciente</h2>
    </div>
    <%= link_to "Ver timeline", project_timeline_path(@project), class: "text-xs font-medium text-purple-600 hover:text-purple-700" %>
  </header>

  <% if @recent_activities.any? %>
    <ul class="px-5 py-4 space-y-4">
      <% @recent_activities.each do |activity| %>
        <li class="flex items-start gap-3">
          <div class="flex-shrink-0">
            <%= user_avatar(activity.user) %>
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-sm text-gray-700">
              <span class="font-medium text-gray-900"><%= activity.user.first_name %></span>
              <%= activity.description %>
            </p>
            <p class="text-xs text-gray-400 mt-0.5"><%= time_ago_in_words(activity.created_at) %> atrás</p>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="px-5 py-10 text-center">
      <svg class="w-10 h-10 mx-auto text-gray-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
      </svg>
      <p class="text-sm text-gray-500">Sin actividad reciente.</p>
    </div>
  <% end %>
</section>
