<section class="bg-white border border-gray-200 rounded-2xl">
  <header class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
    <div class="flex items-center gap-2">
      <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v6a2 2 0 01-2 2h-2a2 2 0 01-2-2V6z"/>
      </svg>
      <h2 class="text-base font-semibold text-gray-900">Tableros</h2>
      <span class="text-xs font-medium text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full"><%= @boards_count %></span>
    </div>
    <%= link_to "Nuevo tablero", new_project_board_path(@project),
          class: "inline-flex items-center gap-1 text-xs font-medium text-purple-600 hover:text-purple-700" %>
  </header>

  <% if @project.boards.any? %>
    <ul class="divide-y divide-gray-100">
      <% @project.boards.limit(4).each do |board| %>
        <li>
          <%= link_to project_board_path(@project, board), class: "flex items-center justify-between px-5 py-3 hover:bg-gray-50 transition-colors" do %>
            <div class="flex items-center gap-3 min-w-0">
              <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center text-amber-600 flex-shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v6a2 2 0 01-2 2h-2a2 2 0 01-2-2V6z"/>
                </svg>
              </div>
              <div class="min-w-0">
                <div class="text-sm font-medium text-gray-900 truncate"><%= board.title %></div>
                <div class="text-xs text-gray-500"><%= board.columns.size %> columnas</div>
              </div>
            </div>
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          <% end %>
        </li>
      <% end %>
    </ul>
    <% if @boards_count > 4 %>
      <div class="px-5 py-3 border-t border-gray-100 text-center">
        <%= link_to "Ver todos los tableros", project_boards_path(@project), class: "text-xs font-medium text-purple-600 hover:text-purple-700" %>
      </div>
    <% end %>
  <% else %>
    <div class="px-5 py-10 text-center">
      <svg class="w-10 h-10 mx-auto text-gray-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v6a2 2 0 01-2 2h-2a2 2 0 01-2-2V6z"/>
      </svg>
      <p class="text-sm text-gray-500 mb-2">Aún no hay tableros.</p>
      <%= link_to "Crear el primer tablero", new_project_board_path(@project),
            class: "inline-block text-xs font-medium text-purple-600 hover:text-purple-700" %>
    </div>
  <% end %>
</section>
