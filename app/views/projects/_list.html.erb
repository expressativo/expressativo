<div data-controller="project-filter" class="space-y-4">
  <div class="flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
    <div class="relative max-w-sm w-full">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z" />
      </svg>
      <input type="text"
             placeholder="Buscar proyectos"
             data-action="input->project-filter#filter"
             data-project-filter-target="input"
             class="w-full pl-9 pr-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" />
    </div>
    <p class="text-xs text-gray-500" data-project-filter-target="counter">
      <%= pluralize(projects.size, "proyecto") %>
    </p>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg">
    <div class="hidden md:grid grid-cols-12 gap-4 px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider bg-gray-50 border-b border-gray-200 rounded-t-lg">
      <div class="col-span-5">Nombre</div>
      <div class="col-span-2">Lead</div>
      <div class="col-span-2">Actividad</div>
      <div class="col-span-2">Equipo</div>
      <div class="col-span-1 text-right">Acciones</div>
    </div>

    <ul data-project-filter-target="list">
      <% projects.each do |project| %>
        <% owner = project.owner %>
        <% members_count = project.users.size %>
        <% todos_count = project.todos.size %>
        <% boards_count = project.boards.size %>
        <li data-project-filter-target="item"
            data-project-name="<%= [project.title, project.description.to_s].join(' ').downcase %>"
            class="border-b border-gray-200 last:border-b-0 last:rounded-b-lg hover:bg-gray-50 transition-colors group">
          <div class="grid grid-cols-12 gap-4 px-4 py-3 items-center">
            <div class="col-span-12 md:col-span-5 min-w-0">
              <%= link_to project_path(project), class: "flex items-center gap-3 min-w-0" do %>
                <div class="w-10 h-10 rounded-md bg-gradient-to-br from-purple-500 to-indigo-600 flex items-center justify-center text-white text-sm font-bold flex-shrink-0">
                  <%= project.title.to_s.first(2).upcase %>
                </div>
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-gray-900 group-hover:text-purple-600 truncate">
                    <%= project.title %>
                  </p>
                  <% if project.description.present? %>
                    <p class="text-xs text-gray-500 truncate">
                      <%= truncate(strip_tags(project.description.to_s), length: 80) %>
                    </p>
                  <% else %>
                    <p class="text-xs text-gray-400 italic">Sin descripción</p>
                  <% end %>
                </div>
              <% end %>
            </div>

            <div class="col-span-6 md:col-span-2 flex items-center gap-2 min-w-0">
              <% if owner.present? %>
                <span title="<%= owner.first_name %> <%= owner.last_name %>">
                  <%= user_avatar(owner) %>
                </span>
                <span class="text-sm text-gray-700 truncate hidden lg:inline">
                  <%= owner.first_name %> <%= owner.last_name %>
                </span>
              <% else %>
                <span class="text-xs text-gray-400">—</span>
              <% end %>
            </div>

            <div class="col-span-6 md:col-span-2 flex items-center gap-3 text-xs text-gray-600">
              <span class="inline-flex items-center gap-1" title="Listas de tareas">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
                <%= todos_count %>
              </span>
              <span class="inline-flex items-center gap-1" title="Tableros">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
                </svg>
                <%= boards_count %>
              </span>
              <span class="text-gray-400 hidden xl:inline">·</span>
              <span class="text-xs text-gray-500 hidden xl:inline">
                <%= time_ago_in_words(project.updated_at) %>
              </span>
            </div>

            <div class="col-span-10 md:col-span-2 flex items-center">
              <div class="flex -space-x-2">
                <% project.users.first(4).each do |member| %>
                  <span title="<%= member.first_name %> <%= member.last_name %>" class="ring-2 ring-white rounded-full">
                    <%= user_avatar(member) %>
                  </span>
                <% end %>
                <% extra = members_count - 4 %>
                <% if extra > 0 %>
                  <div class="w-8 h-8 rounded-full bg-gray-200 ring-2 ring-white flex items-center justify-center text-xs font-medium text-gray-700">
                    +<%= extra %>
                  </div>
                <% end %>
              </div>
            </div>

            <div class="col-span-2 md:col-span-1 flex justify-end">
              <%= render 'projects/option_dropdown', project: project %>
            </div>
          </div>
        </li>
      <% end %>
    </ul>

    <div data-project-filter-target="empty" class="hidden px-4 py-10 text-center text-sm text-gray-500">
      No se encontraron proyectos que coincidan con tu búsqueda.
    </div>
  </div>
</div>
