<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Tivo - Gestión de Proyectos Colaborativa" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="content" description="Tivo">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>
    <% if user_signed_in? %>
      <meta name="current-user-id" content="<%= current_user.id %>">
    <% end %>
    <%= yield :head %>
    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <link rel="icon" href="<%= asset_path 'expressativo_logo.jpg' %>" type="image/png">
    <link rel="icon" href="<%= asset_path 'expressativo_logo.jpg' %>" type="image/svg+xml">
    <link rel="apple-touch-icon" href="<%= asset_path 'expressativo_logo.jpg' %>">
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "lexxy", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "calendar", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "glightbox", "data-turbo-track": "reload" %>
    <%# GLightbox CSS %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox@3.3.1/dist/css/glightbox.min.css">
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-white" data-controller="lightbox reactions-launcher">
    <% if user_signed_in? %>
      <%= render 'layouts/navbar'%>
      <div data-controller="chat-notifier"
           data-chat-notifier-icon-url-value="<%= asset_url('expressativo_logo.jpg') %>"
           hidden></div>
    <% end %>
    <div id="toasts" class="fixed top-4 right-4 z-50 flex flex-col gap-2 pointer-events-none">
      <% if notice %>
        <%= render "shared/toast", message: notice, type: "notice" %>
      <% end %>
      <% if alert %>
        <%= render "shared/toast", message: alert, type: "alert" %>
      <% end %>
    </div>
    <main class="max-w-[1800px] mx-auto px-2 md:px-5 lg:px-6">
      <%= yield %>
    </main>
  </body>
</html>
