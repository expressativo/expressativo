<%= render layout: 'projects/layout', locals: { project: @project, active: :boards } do %>
  <div class="mb-3">
    <%= link_to project_boards_path(@project), class: "inline-flex items-center gap-1.5 text-sm text-gray-600 hover:text-purple-600 transition-colors" do %>
      <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l14 0" /><path d="M5 12l6 6" /><path d="M5 12l6 -6" /></svg>
      Volver a tableros
    <% end %>
  </div>
  <section class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
    <header class="px-6 py-4 border-b border-gray-200">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div class="min-w-0">
          <%= link_to edit_project_board_path(@project, @board), class: "group inline-flex items-center gap-2" do %>
            <h2 class="text-lg font-semibold text-gray-900 group-hover:text-purple-600 transition-colors truncate">
              <%= @board.title %>
            </h2>
            <svg class="w-4 h-4 text-gray-400 opacity-0 group-hover:opacity-100 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
          <% end %>
          <% if @board.description.present? %>
            <p class="text-sm text-gray-500 mt-0.5"><%= @board.description %></p>
          <% end %>
        </div>

        <div class="flex items-center gap-2 flex-shrink-0">
          <%= link_to add_tasks_project_board_path(@project, @board),
                class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white bg-purple-600 hover:bg-purple-700 rounded-md transition shadow-sm" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Agregar tareas
          <% end %>
        </div>
      </div>

      <!-- Filtros (avatares estilo Jira) -->
      <div class="flex items-center gap-3 mt-3 flex-wrap">
        <% if @project_users.any? %>
          <div class="flex -space-x-2">
            <% @project_users.first(8).each do |user| %>
              <% is_selected = params[:assignee_id].to_i == user.id %>
              <%= link_to project_board_path(@project, @board, assignee_id: user.id),
                    title: user.full_name,
                    class: "rounded-full ring-2 transition transform hover:-translate-y-0.5 hover:z-10 #{is_selected ? 'ring-purple-500' : 'ring-white hover:ring-gray-300'}" do %>
                <%= user_avatar(user) %>
              <% end %>
            <% end %>
          </div>

          <%= link_to project_board_path(@project, @board, assignee_id: 'unassigned'),
                title: "Sin asignar",
                class: "w-8 h-8 rounded-full border-2 flex items-center justify-center transition #{params[:assignee_id] == 'unassigned' ? 'border-purple-500 text-purple-600 bg-purple-50' : 'border-dashed border-gray-300 text-gray-400 hover:border-gray-500 hover:text-gray-600'}" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
            </svg>
          <% end %>
        <% end %>

        <% if params[:assignee_id].present? %>
          <%= link_to project_board_path(@project, @board),
                class: "inline-flex items-center gap-1 text-xs text-purple-600 hover:text-purple-800" do %>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
            Limpiar filtros
          <% end %>
        <% end %>
      </div>
    </header>

    <!-- Tablero Kanban -->
    <div
      class="bg-slate-50 p-3 overflow-x-auto"
      data-controller="create-task-modal"
      data-create-task-modal-project-id-value="<%= @project.id %>"
      data-create-task-modal-todos-value="<%= @todos.map { |t| { id: t.id, name: t.name } }.to_json %>">
      <div
        data-controller="kanban board-columns"
        data-board-columns-target="container"
        data-board-columns-project-id-value="<%= @project.id %>"
        data-board-columns-board-id-value="<%= @board.id %>"
        class="flex gap-3 items-start"
        style="min-width: max-content;">

        <% @columns.each do |column| %>
          <div
            class="flex-shrink-0 w-72 bg-slate-100 rounded-lg column-draggable"
            data-column-id="<%= column.id %>"
            data-controller="column-editor"
            data-column-editor-column-id-value="<%= column.id %>"
            data-column-editor-board-id-value="<%= @board.id %>"
            data-column-editor-project-id-value="<%= @project.id %>"
            data-column-editor-update-url-value="<%= project_board_column_path(@project, @board, column) %>">

            <!-- Encabezado de columna -->
            <div class="flex items-center justify-between px-3 pt-3 pb-2 column-drag-handle cursor-grab active:cursor-grabbing">
              <div class="flex items-center gap-2 min-w-0">
                <h3
                  data-column-editor-target="title"
                  data-action="click->column-editor#editTitle"
                  class="text-xs font-semibold text-slate-600 uppercase tracking-wide cursor-pointer hover:text-purple-600 truncate">
                  <%= column.title %>
                </h3>
                <span
                  data-column-task-count
                  class="text-xs font-medium text-slate-600 bg-slate-200 rounded-full px-2 py-0.5 min-w-[1.5rem] text-center">
                  <%= column.tasks.count %>
                </span>
              </div>
            </div>

            <!-- Lista de tareas -->
            <div
              data-kanban-target="column"
              data-column-id="<%= column.id %>"
              class="px-2 pb-2 space-y-2 min-h-[120px]">

              <% column.tasks.each do |task| %>
                <%= render 'boards/task_card', task: task, board: @board, project: @project %>
              <% end %>
            </div>

            <div class="px-2 pb-3">
              <button
                type="button"
                data-action="click->create-task-modal#openFromColumn"
                data-create-task-modal-column-id-param="<%= column.id %>"
                class="w-full flex items-center gap-1.5 text-sm text-slate-500 hover:text-purple-600 hover:bg-white/80 rounded-md px-2 py-1.5 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Crear tarea
              </button>
            </div>
          </div>
        <% end %>

        <!-- Columna para agregar nueva columna -->
        <div
          class="flex-shrink-0 w-72"
          data-controller="column-editor"
          data-column-editor-create-url-value="<%= project_board_columns_path(@project, @board) %>">

          <button
            data-action="click->column-editor#showForm"
            class="w-full flex items-center gap-2 text-sm font-medium text-slate-600 hover:text-slate-900 bg-white/60 hover:bg-white border border-dashed border-slate-300 rounded-lg px-3 py-2.5 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Agregar columna
          </button>

          <!-- Formulario para nueva columna -->
          <div data-column-editor-target="form" class="hidden mt-2 bg-white border border-slate-200 rounded-lg p-2">
            <input
              type="text"
              data-column-editor-target="newColumnTitle"
              placeholder="Nombre de la columna"
              class="w-full border border-slate-300 rounded px-3 py-2 mb-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
              data-action="keydown.enter->column-editor#createColumn keydown.escape->column-editor#cancelCreate">

            <div class="flex gap-2">
              <button
                data-action="click->column-editor#createColumn"
                class="bg-purple-600 text-white px-3 py-1 rounded hover:bg-purple-700 text-sm">
                Agregar
              </button>
              <button
                data-action="click->column-editor#cancelCreate"
                class="bg-slate-200 text-slate-700 px-3 py-1 rounded hover:bg-slate-300 text-sm">
                Cancelar
              </button>
            </div>
          </div>
        </div>
      </div>

      <%= render "shared/create_task_modal", modal_title: "Crear tarea en columna" %>
    </div>
  </section>
<% end %>
