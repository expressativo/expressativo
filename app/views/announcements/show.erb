<% content_for :title, "Anuncio" %>

<%= render layout: 'projects/layout', locals: { project: @project, active: :announcements } do %>
  <article class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
    <header class="flex items-center justify-between gap-4 px-6 py-4 border-b border-gray-100">
      <div class="flex items-center gap-2 min-w-0">
        <span class="w-9 h-9 rounded-lg bg-amber-50 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
          </svg>
        </span>
        <h2 class="text-lg font-semibold text-gray-900 truncate">Anuncio</h2>
        <span class="text-xs text-gray-500">· <%= time_ago_in_words(@announcement.created_at) %> atrás</span>
      </div>
      <%= link_to "Editar", edit_project_announcement_path(@project, @announcement),
          class: "inline-flex items-center px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" %>
    </header>

    <div class="px-6 py-5 trix-content text-gray-900">
      <%= @announcement.content %>
    </div>
  </article>

  <section class="mt-6 bg-white border border-gray-200 rounded-2xl overflow-hidden">
    <header class="px-6 py-4 border-b border-gray-100">
      <h3 class="text-sm font-semibold text-gray-900">Comentarios</h3>
    </header>
    <div class="px-6 py-5 space-y-4">
      <%= render 'announcement_comments/list' %>
      <%= render 'announcement_comments/form' %>
    </div>
  </section>
<% end %>
