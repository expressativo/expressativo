<% content_for :title, "Anuncios" %>

<%= render layout: 'projects/layout', locals: { project: @project, active: :announcements } do %>
  <section class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
    <header class="flex items-center justify-between gap-4 px-6 py-4 border-b border-gray-100">
      <div class="flex items-center gap-2 min-w-0">
        <span class="w-9 h-9 rounded-lg bg-amber-50 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
          </svg>
        </span>
        <h2 class="text-lg font-semibold text-gray-900 truncate">Anuncios del proyecto</h2>
        <span class="text-xs font-medium text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full"><%= @announcements.size %></span>
      </div>
      <%= link_to new_project_announcement_path(@project), class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white bg-purple-600 rounded-lg hover:bg-purple-700 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
        </svg>
        Nuevo anuncio
      <% end %>
    </header>

    <% if @announcements.any? { |a| a.content.present? } %>
      <%= render 'announcements/list' %>
    <% else %>
      <div class="text-center py-16">
        <svg class="w-16 h-16 mx-auto text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
        </svg>
        <p class="text-gray-500 mb-3">Aún no hay anuncios en este proyecto.</p>
        <%= link_to "Crear el primero", new_project_announcement_path(@project), class: "inline-block text-sm font-medium text-purple-600 hover:text-purple-700" %>
      </div>
    <% end %>
  </section>
<% end %>
