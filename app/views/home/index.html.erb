<% content_for :title, "Tivo — Gestión de proyectos colaborativa para equipos modernos" %>
<% content_for :description, "Organiza proyectos, tableros Kanban, calendarios de publicaciones, listas de tareas y anuncios en un solo lugar. Tivo es la plataforma colaborativa para equipos de marketing, producto y startups." %>
<% content_for :canonical, root_url %>
<% content_for :og_image, asset_url("landing/screen-project-show.png") %>

<% content_for :head do %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Tivo",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Plataforma colaborativa para gestionar proyectos, tareas, tableros Kanban, calendarios de publicaciones y documentos en equipo.",
    "url": "<%= root_url %>",
    "image": "<%= asset_url('landing/screen-project-show.png') %>",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "featureList": [
      "Tableros Kanban con drag & drop",
      "Listas de tareas colaborativas",
      "Calendario de publicaciones",
      "Anuncios y comentarios",
      "Gestión de miembros con roles",
      "Documentos compartidos"
    ]
  }
  </script>
<% end %>

<div data-controller="mobile-menu">
  <!-- Navigation -->
  <nav class="fixed top-0 w-full bg-white/85 backdrop-blur-md border-b border-gray-200/70 z-50" aria-label="Navegación principal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <%= link_to root_path, class: "flex items-center gap-2", aria: { label: "Tivo — Inicio" } do %>
          <%= image_tag "expressativo_logo.jpg", alt: "", class: "h-8 w-8 rounded-lg object-cover", aria: { hidden: "true" } %>
          <span class="text-xl font-bold text-gray-900">Tivo</span>
        <% end %>

        <div class="hidden md:flex items-baseline space-x-8">
          <a href="#features" class="text-gray-700 hover:text-purple-600 px-2 py-2 text-sm font-medium transition-colors">Funcionalidades</a>
          <a href="#product-tour" class="text-gray-700 hover:text-purple-600 px-2 py-2 text-sm font-medium transition-colors">Tour del producto</a>
          <a href="#how-it-works" class="text-gray-700 hover:text-purple-600 px-2 py-2 text-sm font-medium transition-colors">Cómo funciona</a>
          <a href="#use-cases" class="text-gray-700 hover:text-purple-600 px-2 py-2 text-sm font-medium transition-colors">Casos de uso</a>
        </div>

        <div class="hidden md:flex items-center space-x-3">
          <%= link_to "Iniciar sesión", new_user_session_path,
              class: "text-gray-700 hover:text-purple-600 px-4 py-2 text-sm font-medium transition-colors" %>
          <%= link_to "Crear cuenta gratis", new_user_registration_path,
              class: "bg-purple-600 hover:bg-purple-700 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition-colors shadow-sm" %>
        </div>

        <button type="button"
                class="md:hidden text-gray-700 hover:text-purple-600 p-2"
                data-action="click->mobile-menu#toggle"
                aria-label="Abrir menú">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <div data-mobile-menu-target="menu" class="hidden md:hidden bg-white border-t border-gray-200">
      <div class="px-4 pt-3 pb-4 space-y-1">
        <a href="#features" class="text-gray-700 hover:text-purple-600 block px-3 py-2 text-base font-medium" data-action="click->mobile-menu#close">Funcionalidades</a>
        <a href="#product-tour" class="text-gray-700 hover:text-purple-600 block px-3 py-2 text-base font-medium" data-action="click->mobile-menu#close">Tour del producto</a>
        <a href="#how-it-works" class="text-gray-700 hover:text-purple-600 block px-3 py-2 text-base font-medium" data-action="click->mobile-menu#close">Cómo funciona</a>
        <a href="#use-cases" class="text-gray-700 hover:text-purple-600 block px-3 py-2 text-base font-medium" data-action="click->mobile-menu#close">Casos de uso</a>
        <div class="border-t border-gray-200 mt-3 pt-3 space-y-2">
          <%= link_to "Iniciar sesión", new_user_session_path,
              class: "text-gray-700 hover:text-purple-600 block px-3 py-2 text-base font-medium" %>
          <%= link_to "Crear cuenta gratis", new_user_registration_path,
              class: "bg-purple-600 hover:bg-purple-700 text-white block text-center px-3 py-2 rounded-lg text-base font-semibold" %>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <header class="relative pt-32 pb-20 bg-gradient-to-b from-purple-50 via-white to-white overflow-hidden">
    <div class="absolute inset-x-0 top-24 -z-0 flex justify-center pointer-events-none" aria-hidden="true">
      <div class="h-72 w-[42rem] bg-gradient-to-r from-purple-300/40 via-fuchsia-200/40 to-indigo-300/40 blur-3xl rounded-full"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-purple-100 text-purple-700 text-xs font-semibold tracking-wide uppercase mb-6">
        Hecho para equipos que se mueven rápido
      </span>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 leading-tight max-w-4xl mx-auto">
        Gestiona proyectos con tu equipo,
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-indigo-600">sin caos</span>
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
        Tableros Kanban, listas de tareas, calendarios de publicaciones, anuncios y documentos: todo en un solo espacio colaborativo, listo en minutos.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <%= link_to "Crear cuenta gratis", new_user_registration_path,
            class: "px-7 py-3.5 bg-purple-600 hover:bg-purple-700 text-white font-semibold rounded-lg shadow-md hover:shadow-lg transition-all text-base" %>
        <a href="#product-tour"
           class="px-7 py-3.5 bg-white hover:bg-gray-50 text-gray-800 font-semibold rounded-lg shadow-sm border border-gray-200 transition-all text-base">
          Ver el producto
        </a>
      </div>
      <p class="mt-4 text-sm text-gray-500">No requiere tarjeta de crédito · Configura tu primer proyecto en 2 minutos</p>
    </div>

    <!-- Hero screenshot -->
    <figure class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 mt-14">
      <div class="rounded-2xl bg-white shadow-2xl ring-1 ring-gray-200 overflow-hidden">
        <%= image_tag "landing/screen-project-show.png",
            alt: "Panel de resumen de un proyecto en Tivo con métricas de tareas pendientes, completadas, próximas tareas y publicaciones",
            class: "w-full h-auto block",
            width: 2880, height: 1800, loading: "eager", fetchpriority: "high" %>
      </div>
      <figcaption class="sr-only">Vista del dashboard de proyecto en Tivo</figcaption>
    </figure>
  </header>

  <!-- Trust strip -->
  <section class="py-10 bg-white border-y border-gray-100" aria-label="Resultados clave">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div>
        <p class="text-3xl font-bold text-gray-900">2&nbsp;min</p>
        <p class="text-sm text-gray-500 mt-1">Para crear tu primer proyecto</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-gray-900">∞</p>
        <p class="text-sm text-gray-500 mt-1">Proyectos y tareas, sin límites</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-gray-900">1&nbsp;link</p>
        <p class="text-sm text-gray-500 mt-1">Para invitar a todo tu equipo</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-gray-900">100%</p>
        <p class="text-sm text-gray-500 mt-1">En la nube, desde cualquier dispositivo</p>
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section id="features" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Todo lo que tu equipo necesita</h2>
        <p class="mt-4 text-lg text-gray-600">Funcionalidades pensadas para que dejes de saltar entre cinco herramientas distintas.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <article class="p-6 rounded-2xl border border-gray-200 hover:border-purple-300 hover:shadow-md transition-all">
          <div class="w-11 h-11 bg-purple-100 text-purple-600 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h6v12H4zM14 6h6v8h-6z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Tableros Kanban</h3>
          <p class="text-gray-600 text-sm">Visualiza el flujo de tu sprint con columnas personalizables y drag & drop sobre tareas reales del proyecto.</p>
        </article>

        <article class="p-6 rounded-2xl border border-gray-200 hover:border-indigo-300 hover:shadow-md transition-all">
          <div class="w-11 h-11 bg-indigo-100 text-indigo-600 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Listas de tareas</h3>
          <p class="text-gray-600 text-sm">Agrupa tareas por listas, asigna responsables y fechas, y marca el avance con un solo clic.</p>
        </article>

        <article class="p-6 rounded-2xl border border-gray-200 hover:border-blue-300 hover:shadow-md transition-all">
          <div class="w-11 h-11 bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Calendario de publicaciones</h3>
          <p class="text-gray-600 text-sm">Planifica contenido por día y mes, arrastra publicaciones entre fechas y mantén el roadmap visible para todos.</p>
        </article>

        <article class="p-6 rounded-2xl border border-gray-200 hover:border-pink-300 hover:shadow-md transition-all">
          <div class="w-11 h-11 bg-pink-100 text-pink-600 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Anuncios y comentarios</h3>
          <p class="text-gray-600 text-sm">Comunica decisiones y novedades en el proyecto sin perder contexto entre Slack, email y reuniones.</p>
        </article>

        <article class="p-6 rounded-2xl border border-gray-200 hover:border-emerald-300 hover:shadow-md transition-all">
          <div class="w-11 h-11 bg-emerald-100 text-emerald-600 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Documentos del proyecto</h3>
          <p class="text-gray-600 text-sm">Sube archivos, controla estados (borrador, publicado, archivado) y centraliza la documentación del equipo.</p>
        </article>

        <article class="p-6 rounded-2xl border border-gray-200 hover:border-amber-300 hover:shadow-md transition-all">
          <div class="w-11 h-11 bg-amber-100 text-amber-600 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Miembros e invitaciones</h3>
          <p class="text-gray-600 text-sm">Invita a tu equipo con un link único, asigna roles (owner o miembro) y revoca accesos cuando quieras.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Product tour with real screenshots -->
  <section id="product-tour" class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Un tour rápido por Tivo</h2>
        <p class="mt-4 text-lg text-gray-600">Estas son capturas reales del producto, no mockups.</p>
      </div>

      <!-- Block 1 -->
      <div class="grid lg:grid-cols-2 gap-12 items-center mb-24">
        <div>
          <span class="inline-block px-3 py-1 rounded-full bg-purple-100 text-purple-700 text-xs font-semibold uppercase tracking-wide mb-4">Tableros Kanban</span>
          <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">Visualiza el sprint en una sola pantalla</h3>
          <p class="text-gray-600 text-lg mb-6">Crea columnas personalizadas, arrastra tareas entre estados y ve de un vistazo qué está bloqueado, en revisión o ya cerrado. Sin recargar la página, sin perder el foco.</p>
          <ul class="space-y-3 text-gray-700">
            <li class="flex gap-3"><span class="text-purple-600 mt-1">✓</span><span>Drag &amp; drop fluido entre columnas, con orden persistente.</span></li>
            <li class="flex gap-3"><span class="text-purple-600 mt-1">✓</span><span>Estados sincronizados con las listas de tareas del proyecto.</span></li>
            <li class="flex gap-3"><span class="text-purple-600 mt-1">✓</span><span>Filtros por miembro asignado, etiquetas y fecha.</span></li>
          </ul>
        </div>
        <figure class="rounded-2xl overflow-hidden ring-1 ring-gray-200 shadow-xl bg-white order-first lg:order-last">
          <%= image_tag "landing/screen-board-kanban.png",
              alt: "Tablero Kanban del sprint 12 en Tivo con cuatro columnas — Por hacer, En progreso, En revisión y Completado — y tarjetas de tareas reales",
              class: "w-full h-auto block", loading: "lazy" %>
        </figure>
      </div>

      <!-- Block 2 -->
      <div class="grid lg:grid-cols-2 gap-12 items-center mb-24">
        <figure class="rounded-2xl overflow-hidden ring-1 ring-gray-200 shadow-xl bg-white">
          <%= image_tag "landing/screen-todos.png",
              alt: "Listas de tareas agrupadas por equipo — Backend, Diseño y Marketing — con checkboxes, progreso por lista y tareas tachadas al completarse",
              class: "w-full h-auto block", loading: "lazy" %>
        </figure>
        <div>
          <span class="inline-block px-3 py-1 rounded-full bg-indigo-100 text-indigo-700 text-xs font-semibold uppercase tracking-wide mb-4">Listas de tareas</span>
          <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">Tareas, organizadas como tu equipo trabaja</h3>
          <p class="text-gray-600 text-lg mb-6">Crea listas por área, sprint o iniciativa. Cada tarea tiene fechas, notas enriquecidas, comentarios y asignaciones múltiples. Marca el avance con un check y todo el equipo lo ve al instante.</p>
          <ul class="space-y-3 text-gray-700">
            <li class="flex gap-3"><span class="text-indigo-600 mt-1">✓</span><span>Progreso visible por lista, con barra y contador.</span></li>
            <li class="flex gap-3"><span class="text-indigo-600 mt-1">✓</span><span>Notas con formato enriquecido (Action Text).</span></li>
            <li class="flex gap-3"><span class="text-indigo-600 mt-1">✓</span><span>Comentarios, menciones y notificaciones por email.</span></li>
          </ul>
        </div>
      </div>

      <!-- Block 3 -->
      <div class="grid lg:grid-cols-2 gap-12 items-center mb-24">
        <div>
          <span class="inline-block px-3 py-1 rounded-full bg-blue-100 text-blue-700 text-xs font-semibold uppercase tracking-wide mb-4">Calendario</span>
          <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">Planifica publicaciones mes a mes</h3>
          <p class="text-gray-600 text-lg mb-6">Pensado para equipos de contenido y marketing: arrastra publicaciones entre fechas, vinculadas a tareas del proyecto, y mantén a todo el equipo alineado con el calendario editorial.</p>
          <ul class="space-y-3 text-gray-700">
            <li class="flex gap-3"><span class="text-blue-600 mt-1">✓</span><span>Vista mensual limpia con navegación entre meses.</span></li>
            <li class="flex gap-3"><span class="text-blue-600 mt-1">✓</span><span>Cada publicación queda enlazada a su tarea.</span></li>
            <li class="flex gap-3"><span class="text-blue-600 mt-1">✓</span><span>Cambia fechas arrastrando, sin formularios.</span></li>
          </ul>
        </div>
        <figure class="rounded-2xl overflow-hidden ring-1 ring-gray-200 shadow-xl bg-white order-first lg:order-last">
          <%= image_tag "landing/screen-calendar.png",
              alt: "Calendario mensual de publicaciones del proyecto en Tivo, con publicaciones distribuidas entre los días del mes y enlazadas a tareas",
              class: "w-full h-auto block", loading: "lazy" %>
        </figure>
      </div>

      <!-- Block 4 -->
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <figure class="rounded-2xl overflow-hidden ring-1 ring-gray-200 shadow-xl bg-white">
          <%= image_tag "landing/screen-members.png",
              alt: "Pantalla de miembros del proyecto en Tivo con el equipo listado, sus roles y un link único de invitación copiable",
              class: "w-full h-auto block", loading: "lazy" %>
        </figure>
        <div>
          <span class="inline-block px-3 py-1 rounded-full bg-emerald-100 text-emerald-700 text-xs font-semibold uppercase tracking-wide mb-4">Equipo</span>
          <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">Invita a tu equipo con un solo link</h3>
          <p class="text-gray-600 text-lg mb-6">Genera un link de invitación único por proyecto. Cualquier persona con ese link se une como miembro; tú decides quién es owner. Si rotas el link, los anteriores quedan revocados automáticamente.</p>
          <ul class="space-y-3 text-gray-700">
            <li class="flex gap-3"><span class="text-emerald-600 mt-1">✓</span><span>Roles claros: owner y miembro, sin matrices complejas.</span></li>
            <li class="flex gap-3"><span class="text-emerald-600 mt-1">✓</span><span>Regenera el link cuando lo necesites.</span></li>
            <li class="flex gap-3"><span class="text-emerald-600 mt-1">✓</span><span>Email de bienvenida automático a nuevos miembros.</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section id="how-it-works" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Cómo empezar con Tivo</h2>
        <p class="mt-4 text-lg text-gray-600">Cuatro pasos. Sin onboarding pesado, sin sales calls.</p>
      </div>

      <ol class="grid md:grid-cols-4 gap-6">
        <li class="text-center">
          <div class="w-12 h-12 mx-auto bg-purple-600 text-white rounded-full flex items-center justify-center font-bold text-lg mb-3">1</div>
          <h3 class="font-semibold text-gray-900">Crea tu cuenta</h3>
          <p class="text-gray-600 text-sm mt-1">Regístrate gratis con tu email. Cero fricción.</p>
        </li>
        <li class="text-center">
          <div class="w-12 h-12 mx-auto bg-purple-600 text-white rounded-full flex items-center justify-center font-bold text-lg mb-3">2</div>
          <h3 class="font-semibold text-gray-900">Crea un proyecto</h3>
          <p class="text-gray-600 text-sm mt-1">Dale nombre, descripción y elige si activas el calendario.</p>
        </li>
        <li class="text-center">
          <div class="w-12 h-12 mx-auto bg-purple-600 text-white rounded-full flex items-center justify-center font-bold text-lg mb-3">3</div>
          <h3 class="font-semibold text-gray-900">Invita al equipo</h3>
          <p class="text-gray-600 text-sm mt-1">Copia el link único de invitación y compártelo.</p>
        </li>
        <li class="text-center">
          <div class="w-12 h-12 mx-auto bg-purple-600 text-white rounded-full flex items-center justify-center font-bold text-lg mb-3">4</div>
          <h3 class="font-semibold text-gray-900">Empieza a colaborar</h3>
