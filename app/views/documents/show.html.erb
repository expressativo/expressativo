<% content_for :title, @document.name %>
<% kind = document_kind(@document) %>

<%= render layout: 'projects/layout', locals: { project: @project, active: :documents } do %>
  <% back_url = @document.folder ? project_folder_path(@project, @document.folder) : project_folders_path(@project) %>
  <% back_label = @document.folder ? @document.folder.name : "Documentos" %>

  <section class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
    <header class="flex items-start justify-between gap-4 px-6 py-4 border-b border-gray-100">
      <div class="flex items-start gap-3 min-w-0">
        <%= link_to back_url, class: "p-1.5 rounded-full text-gray-500 hover:bg-gray-100 hover:text-gray-700 transition-colors flex-shrink-0 mt-1.5", title: "Volver a #{back_label}", "aria-label": "Volver a #{back_label}" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        <% end %>
        <%= document_kind_icon(@document, css_class: "w-12 h-12") %>
        <div class="min-w-0">
          <h1 class="text-xl font-bold text-gray-900 truncate"><%= @document.name %></h1>
          <p class="text-xs text-gray-500 mt-0.5">
            <%= document_kind_label(@document) %>
            <% if @document.file.attached? %>
              · <%= document_size(@document) %>
            <% end %>
            · <%= @document.created_by&.full_name %>
            · <%= l(@document.updated_at, format: :long) rescue @document.updated_at.strftime("%d/%m/%Y") %>
          </p>
        </div>
      </div>

      <div class="flex items-center gap-2 flex-shrink-0">
        <%= link_to edit_document_path(@document), class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
          Editar
        <% end %>
        <% if @document.file.attached? %>
          <%= link_to download_document_path(@document), class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white bg-purple-600 rounded-lg hover:bg-purple-700 transition-colors" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            Descargar
          <% end %>
        <% end %>
        <%= button_to document_path(@document), method: :delete,
                      data: { turbo_confirm: "¿Eliminar este documento?" },
                      class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-red-600 bg-white border border-red-200 rounded-lg hover:bg-red-50 transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"/>
          </svg>
          Eliminar
        <% end %>
      </div>
    </header>

    <div class="p-6">
      <% if kind == :rich_text %>
        <div class="prose max-w-none" id="document-content" data-controller="document-images">
          <%= @document.body %>
        </div>

      <% elsif kind == :image %>
        <div class="flex justify-center bg-gray-50 rounded-xl p-4">
          <% if @document.file.content_type == "image/svg+xml" %>
            <%= document_svg_inline(@document, class: "max-w-full max-h-[80vh] flex items-center justify-center") || content_tag(:p, "No se pudo previsualizar el SVG.", class: "text-sm text-gray-500") %>
          <% else %>
            <%= image_tag url_for(@document.file), class: "max-w-full max-h-[80vh] rounded shadow" %>
          <% end %>
        </div>

      <% elsif kind == :pdf %>
        <div class="rounded-xl overflow-hidden border border-gray-200">
          <iframe src="<%= url_for(@document.file) %>" class="w-full h-[80vh]" frameborder="0"></iframe>
        </div>

      <% elsif kind == :video %>
        <div class="flex justify-center bg-black rounded-xl overflow-hidden">
          <video controls class="max-w-full max-h-[80vh]">
            <source src="<%= url_for(@document.file) %>" type="<%= @document.file.content_type %>">
            Tu navegador no soporta video HTML5.
          </video>
        </div>

      <% elsif kind == :audio %>
        <div class="flex justify-center py-8">
          <audio controls class="w-full max-w-xl">
            <source src="<%= url_for(@document.file) %>" type="<%= @document.file.content_type %>">
            Tu navegador no soporta audio HTML5.
          </audio>
        </div>

      <% elsif kind == :text %>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-800 overflow-auto max-h-[70vh] whitespace-pre-wrap"><%= @document.file.download.force_encoding("UTF-8") rescue "(No se pudo leer el contenido)" %></pre>

      <% else %>
        <div class="text-center py-12 border-2 border-dashed border-gray-200 rounded-xl">
          <%= document_kind_icon(@document, css_class: "w-20 h-20 mx-auto") %>
          <p class="mt-3 font-semibold text-gray-700"><%= @document.file.filename %></p>
          <p class="text-sm text-gray-500"><%= document_size(@document) %></p>
          <p class="text-xs text-gray-400 mt-2">Vista previa no disponible para este tipo de archivo.</p>
          <%= link_to "Descargar archivo", download_document_path(@document), class: "inline-block mt-4 inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-white bg-purple-600 rounded-lg hover:bg-purple-700 transition-colors" %>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

