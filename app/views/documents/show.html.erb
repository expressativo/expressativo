<% content_for :title, @document.name %>
<% kind = document_kind(@document) %>

<%= render layout: 'projects/layout', locals: { project: @project, active: :documents } do %>
  <% back_url = @document.folder ? project_folder_path(@project, @document.folder) : project_folders_path(@project) %>
  <% back_label = @document.folder ? @document.folder.name : "Documentos" %>

  <section class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
    <header class="flex items-start justify-between gap-4 px-6 py-4 border-b border-gray-100">
      <div class="flex items-start gap-3 min-w-0">
        <%= link_to back_url, class: "p-1.5 rounded-full text-gray-500 hover:bg-gray-100 hover:text-gray-700 transition-colors flex-shrink-0 mt-1.5", title: "Volver a #{back_label}", "aria-label": "Volver a #{back_label}" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        <% end %>
        <%= document_kind_icon(@document, css_class: "w-12 h-12") %>
        <div class="min-w-0">
          <div class="flex items-center gap-2">
            <h1 class="text-xl font-bold text-gray-900 truncate"><%= @document.name %></h1>
            <% unless @document.published? %>
              <span class="inline-flex items-center px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider rounded
                    <%= @document.draft? ? 'bg-gray-100 text-gray-600' : 'bg-amber-100 text-amber-700' %>">
                <%= @document.draft? ? 'Borrador' : 'Archivado' %>
              </span>
            <% end %>
          </div>
          <p class="text-xs text-gray-500 mt-0.5">
            <%= document_kind_label(@document) %>
            <% if @document.file.attached? %>
              · <%= document_size(@document) %>
            <% end %>
            · <%= @document.created_by&.full_name %>
            · <%= l(@document.updated_at, format: :long) rescue @document.updated_at.strftime("%d/%m/%Y") %>
          </p>
        </div>
      </div>

      <div class="flex items-center gap-2 flex-shrink-0">
        <% can_change_status = @document.can_be_published_by?(current_user) %>

        <% if @document.draft? && can_change_status %>
          <%= button_to publish_document_path(@document), method: :patch,
                        class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white bg-emerald-600 rounded-lg hover:bg-emerald-700 transition-colors" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Publicar
          <% end %>
        <% end %>

        <% if @document.published? && can_change_status %>
          <% confirm_message = @document.public? ? "¿Mover este documento a borrador? El link público también será revocado." : "¿Mover este documento a borrador?" %>
          <%= button_to unpublish_document_path(@document), method: :patch,
                        data: { turbo_confirm: confirm_message },
                        class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors",
                        title: "Mover a borrador" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
            </svg>
            Despublicar
          <% end %>
        <% end %>

        <div data-controller="dropdown" class="relative">
          <button type="button"
                  data-dropdown-target="button"
                  data-action="click->dropdown#toggle"
                  aria-haspopup="true"
                  aria-expanded="false"
                  aria-label="Más acciones"
                  class="inline-flex items-center justify-center w-9 h-9 text-gray-500 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 hover:text-gray-700 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01"/>
            </svg>
          </button>

          <div data-dropdown-target="menu" class="hidden absolute right-0 z-20 mt-2 w-56 bg-white rounded-lg shadow-lg border border-gray-200 overflow-hidden">
            <ul class="py-1 text-sm text-gray-700">
              <li>
                <%= link_to edit_document_path(@document), class: "flex items-center gap-2.5 px-4 py-2 hover:bg-gray-100 transition-colors" do %>
                  <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                  </svg>
                  Editar
                <% end %>
              </li>

              <% if @document.file.attached? %>
                <li>
                  <%= link_to download_document_path(@document), class: "flex items-center gap-2.5 px-4 py-2 hover:bg-gray-100 transition-colors" do %>
                    <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                    </svg>
                    Descargar
                  <% end %>
                </li>
              <% end %>

              <% if can_change_status %>
                <li class="border-t border-gray-100">
                  <% if @document.public? %>
                    <%= button_to unpublish_public_document_path(@document), method: :patch,
                                  form: { data: { turbo_confirm: "¿Revocar el link público? Cualquiera que lo tenga dejará de poder ver el documento." }, class: "w-full" },
                                  class: "flex items-center gap-2.5 w-full px-4 py-2 text-left hover:bg-gray-100 transition-colors" do %>
                      <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                      </svg>
                      Hacer privado
                    <% end %>
                  <% else %>
                    <%= button_to publish_public_document_path(@document), method: :patch,
                                  form: { class: "w-full" },
                                  class: "flex items-center gap-2.5 w-full px-4 py-2 text-left hover:bg-gray-100 transition-colors" do %>
                      <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 015.656 0l1.414 1.414a4 4 0 010 5.656l-3.536 3.536a4 4 0 01-5.656 0l-1.414-1.414M10.172 13.828a4 4 0 01-5.656 0L3.1 12.414a4 4 0 010-5.656L6.636 3.222a4 4 0 015.656 0l1.414 1.414"/>
                      </svg>
                      Compartir público
                    <% end %>
                  <% end %>
                </li>

                <li>
                  <% if @document.archived? %>
                    <%= button_to unarchive_document_path(@document), method: :patch,
                                  form: { class: "w-full" },
                                  class: "flex items-center gap-2.5 w-full px-4 py-2 text-left hover:bg-gray-100 transition-colors" do %>
                      <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/>
                      </svg>
                      Restaurar
                    <% end %>
                  <% else %>
                    <%= button_to archive_document_path(@document), method: :patch,
                                  form: { data: { turbo_confirm: "¿Archivar este documento?" }, class: "w-full" },
                                  class: "flex items-center gap-2.5 w-full px-4 py-2 text-left hover:bg-gray-100 transition-colors" do %>
                      <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
                      </svg>
                      Archivar
                    <% end %>
                  <% end %>
                </li>
              <% end %>

              <li class="border-t border-gray-100">
                <%= button_to document_path(@document), method: :delete,
                              form: { data: { turbo_confirm: "¿Eliminar este documento?" }, class: "w-full" },
                              class: "flex items-center gap-2.5 w-full px-4 py-2 text-left text-red-600 hover:bg-red-50 transition-colors" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"/>
                  </svg>
                  Eliminar
                <% end %>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </header>

    <% if @document.public? %>
      <% public_url = public_document_url(@document.public_token) %>
      <div class="px-6 py-3 bg-sky-50 border-b border-sky-100" data-controller="clipboard">
        <div class="flex items-center gap-3">
          <div class="flex items-center gap-2 text-sky-700 flex-shrink-0">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 015.656 0l1.414 1.414a4 4 0 010 5.656l-3.536 3.536a4 4 0 01-5.656 0l-1.414-1.414M10.172 13.828a4 4 0 01-5.656 0L3.1 12.414a4 4 0 010-5.656L6.636 3.222a4 4 0 015.656 0l1.414 1.414"/>
            </svg>
            <span class="text-xs font-semibold uppercase tracking-wider">Link público</span>
          </div>
          <input type="text"
                 value="<%= public_url %>"
                 readonly
                 data-clipboard-target="source"
                 class="flex-1 min-w-0 px-3 py-1.5 text-sm bg-white border border-sky-200 rounded-md text-gray-700 focus:outline-none focus:ring-2 focus:ring-sky-300">
          <button type="button"
                  data-action="click->clipboard#copy"
                  data-clipboard-target="button"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white bg-sky-600 rounded-md hover:bg-sky-700 transition-colors flex-shrink-0">
            Copiar
          </button>
        </div>
      </div>
    <% end %>

    <div class="p-6">
      <% if kind == :rich_text %>
        <div class="prose max-w-none" id="document-content" data-controller="document-images">
          <%= @document.body %>
        </div>

      <% elsif kind == :image %>
        <div class="flex justify-center bg-gray-50 rounded-xl p-4">
          <%= image_tag url_for(@document.file), class: "max-w-full max-h-[80vh] rounded shadow" %>
        </div>

      <% elsif kind == :pdf %>
        <div class="rounded-xl overflow-hidden border border-gray-200">
          <iframe src="<%= url_for(@document.file) %>" class="w-full h-[80vh]" frameborder="0"></iframe>
        </div>

      <% elsif kind == :video %>
        <div class="flex justify-center bg-black rounded-xl overflow-hidden">
          <video controls class="max-w-full max-h-[80vh]">
            <source src="<%= url_for(@document.file) %>" type="<%= @document.file.content_type %>">
            Tu navegador no soporta video HTML5.
          </video>
        </div>

      <% elsif kind == :audio %>
        <div class="flex justify-center py-8">
          <audio controls class="w-full max-w-xl">
            <source src="<%= url_for(@document.file) %>" type="<%= @document.file.content_type %>">
            Tu navegador no soporta audio HTML5.
          </audio>
        </div>

      <% elsif kind == :text %>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-800 overflow-auto max-h-[70vh] whitespace-pre-wrap"><%= @document.file.download.force_encoding("UTF-8") rescue "(No se pudo leer el contenido)" %></pre>

      <% else %>
        <div class="text-center py-12 border-2 border-dashed border-gray-200 rounded-xl">
          <%= document_kind_icon(@document, css_class: "w-20 h-20 mx-auto") %>
          <p class="mt-3 font-semibold text-gray-700"><%= @document.file.filename %></p>
          <p class="text-sm text-gray-500"><%= document_size(@document) %></p>
          <p class="text-xs text-gray-400 mt-2">Vista previa no disponible para este tipo de archivo.</p>
          <%= link_to "Descargar archivo", download_document_path(@document), class: "inline-block mt-4 inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-white bg-purple-600 rounded-lg hover:bg-purple-700 transition-colors" %>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

