<% content_for :title, "Campos personalizados" %>

<%= render layout: 'projects/layout', locals: { project: @project, active: :custom_fields } do %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="lg:col-span-2 space-y-4">
      <section class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
        <header class="flex items-center gap-4 px-6 py-4 border-b border-gray-100">
          <span class="w-9 h-9 rounded-lg bg-indigo-50 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h10M4 18h6"/>
            </svg>
          </span>
          <div class="flex items-center gap-2 min-w-0">
            <h2 class="text-lg font-semibold text-gray-900 truncate">Campos personalizados</h2>
            <span class="text-xs font-medium text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full">
              <%= @custom_fields.size %>
            </span>
          </div>
        </header>

        <% if @custom_fields.any? %>
          <ul class="divide-y divide-gray-100">
            <% @custom_fields.each do |field| %>
              <li class="flex items-center justify-between gap-4 px-6 py-4 group hover:bg-gray-50 transition-colors">
                <div class="flex items-center gap-3 min-w-0">
                  <span class="w-8 h-8 rounded-lg bg-gray-100 flex items-center justify-center flex-shrink-0 text-gray-500">
                    <% case field.field_type %>
                    <% when "text" %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16"/></svg>
                    <% when "number" %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"/></svg>
                    <% when "date" %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    <% when "select" %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4"/></svg>
                    <% end %>
                  </span>
                  <div class="min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                      <span class="text-sm font-semibold text-gray-900 truncate"><%= field.name %></span>
                      <span class="inline-flex items-center px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider bg-indigo-100 text-indigo-700 rounded">
                        <%= { "text" => "Texto", "number" => "Número", "date" => "Fecha", "select" => "Selección" }[field.field_type] %>
                      </span>
                    </div>
                    <% if field.field_type == "select" && field.options_list.any? %>
                      <p class="text-xs text-gray-500 mt-0.5 truncate">
                        Opciones: <%= field.options_list.join(", ") %>
                      </p>
                    <% end %>
                    <% if field.key.present? %>
                      <p class="text-xs text-indigo-500 mt-0.5">
                        Clave: <code class="bg-indigo-50 px-1 rounded"><%= field.key %></code>
                      </p>
                    <% end %>
                  </div>
                </div>

                <%= button_to project_custom_field_path(@project, field),
                              method: :delete,
                              form: { data: { turbo_confirm: "¿Eliminar el campo \"#{field.name}\"? Se perderán todos sus valores." } },
                              class: "opacity-0 group-hover:opacity-100 p-1.5 rounded-md text-red-600 hover:bg-red-50 transition cursor-pointer",
                              title: "Eliminar campo" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"/>
                  </svg>
                <% end %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="text-center py-12 text-gray-400">
            <svg class="w-10 h-10 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 10h16M4 14h10M4 18h6"/>
            </svg>
            <p class="text-sm">No hay campos personalizados todavía.</p>
            <p class="text-xs mt-1">Agrega el primero usando el formulario.</p>
          </div>
        <% end %>
      </section>
    </div>

    <div>
      <section class="bg-white border border-gray-200 rounded-2xl p-5" data-controller="custom-field-form">
        <div class="flex items-center gap-2 mb-4">
          <span class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
          </span>
          <h3 class="text-base font-semibold text-gray-900">Nuevo campo</h3>
        </div>

        <%= form_with model: [@project, @custom_field], url: project_custom_fields_path(@project), class: "space-y-3" do |f| %>
          <div>
            <%= f.label :name, "Nombre del campo", class: "block text-xs font-medium text-gray-700 mb-1" %>
            <%= f.text_field :name,
                placeholder: "ej: Prioridad, Sprint, URL de Figma",
                required: true,
                class: "w-full px-3 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>

          <div>
            <%= f.label :field_type, "Tipo", class: "block text-xs font-medium text-gray-700 mb-1" %>
            <%= f.select :field_type,
                [["Texto", "text"], ["Número", "number"], ["Fecha", "date"], ["Selección", "select"]],
                {},
                class: "w-full px-3 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500",
                data: { action: "change->custom-field-form#toggleOptions", "custom-field-form-target": "typeSelect" } %>
          </div>

          <div>
            <%= f.label :key, class: "block text-xs font-medium text-gray-700 mb-1" do %>
              Clave <span class="text-gray-400 font-normal">(opcional)</span>
            <% end %>
            <%= f.text_field :key,
                placeholder: "ej: location",
                class: "w-full px-3 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
            <p class="mt-1 text-[11px] text-gray-400">Usa <code class="bg-gray-100 px-1 rounded">location</code> para ubicación, <code class="bg-gray-100 px-1 rounded">duration</code> para duración en minutos</p>
          </div>

          <div data-custom-field-form-target="optionsField" class="hidden">
            <label class="block text-xs font-medium text-gray-700 mb-1">
              Opciones
              <span class="text-gray-400 font-normal">(separadas por coma)</span>
            </label>
            <input type="text"
                   name="project_custom_field[options_raw]"
                   placeholder="ej: Alta, Media, Baja"
                   class="w-full px-3 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500"
                   data-custom-field-form-target="optionsInput" />
          </div>

          <%= f.submit "Agregar campo",
              class: "w-full inline-flex items-center justify-center gap-1.5 px-3 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
        <% end %>
      </section>
    </div>
  </div>
<% end %>
