<div>
  <div class="card max-w-[95%] mx-auto mb-[-10px] p-4">
    <% if params[:from] == 'board' %>
      <div class="flex items-center">
        <%= link_to :back, class: "inline-flex items-center gap-2 px-4 py-2 text-gray-700 hover:text-blue-600 hover:bg-gray-50 rounded-lg transition-colors font-medium" do %>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l14 0" /><path d="M5 12l6 6" /><path d="M5 12l6 -6" /></svg>
          Volver al tablero
        <% end %>
      </div>
    <% elsif params[:from] == 'calendar' %>
      <div class="flex items-center">
        <% 
          # Obtener el mes y año de la publicación asociada a la tarea
          publication_date = @task.publication&.publication_date || Date.today
          calendar_params = { year: publication_date.year, month: publication_date.month }
        %>
        <%= link_to project_publications_path(@project, calendar_params), class: "inline-flex items-center gap-2 px-4 py-2 text-gray-700 hover:text-blue-600 hover:bg-gray-50 rounded-lg transition-colors font-medium" do %>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l14 0" /><path d="M5 12l6 6" /><path d="M5 12l6 -6" /></svg>
          Volver al calendario
        <% end %>
      </div>
    <% else %>
      <%= render 'tasks/bread_crumbs'%>
    <% end %>
  </div>
  <div class="card py-4 px-2">
    <div class="flex justify-end items-center px-4 mb-2 gap-2">
      <%= link_to edit_project_todo_task_path(@project, @todo, @task), 
                  data: { turbo_frame: "#{dom_id(@task)}_show" },
                  class: "text-gray-600 hover:text-blue-600" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-edit"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" /><path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z" /><path d="M16 5l3 3" /></svg>
      <% end %>

      <%= link_to project_todo_task_path(@project, @todo, @task), 
                  class: 'text-gray-600 hover:text-red-800', 
                  data: {
                    turbo_method: :delete,
                    turbo_confirm: '¿Estás seguro de que quieres eliminar esta tarea?',
                  } do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-trash"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M4 7l16 0" /><path d="M10 11l0 6" /><path d="M14 11l0 6" /><path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" /><path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" /></svg>
      <% end %>
    </div>
    <%= turbo_frame_tag "#{dom_id(@task)}_show" do %>
      <%= render 'tasks/tasks_info', task: @task %>
    <% end %>
    <section
      class="md:max-w-4xl m-auto mt-4"
      data-controller="text-selection-menu"
      data-text-selection-menu-project-id-value="<%= @project.id %>"
      data-text-selection-menu-todos-value="<%= @project.todos.map { |t| { id: t.id, name: t.name } }.to_json.html_safe %>"
    >
      <div id="flash-messages"></div>
      <%= render 'tasks/comments/list' %>
      <div class="mt-4">
        <%= render 'tasks/comments/form' %>
      </div>

      <%# Floating text-selection menu %>
      <div
        class="hidden fixed z-50 bg-white shadow-lg rounded-lg border border-gray-200 py-1 min-w-max"
        data-text-selection-menu-target="menu"
      >
        <button
          class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 w-full text-left transition-colors"
          data-action="click->text-selection-menu#openCreateTaskModal"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 5v14M5 12h14"/>
          </svg>
          Crear tarea
        </button>
      </div>

      <%# Create task from selection modal %>
      <div
        class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50"
        data-text-selection-menu-target="modal"
        data-action="click->text-selection-menu#backdropClick"
      >
        <div class="bg-white rounded-xl shadow-2xl p-6 max-w-md w-full mx-4">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-base font-semibold text-gray-900">Crear tarea desde selección</h3>
            <button
              type="button"
              class="text-gray-400 hover:text-gray-600 transition-colors"
              data-action="click->text-selection-menu#closeModal"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 6 6 18M6 6l12 12"/>
              </svg>
            </button>
          </div>

          <form data-action="submit->text-selection-menu#createTask">
            <div class="mb-4">
              <label class="block text-sm font-medium text-gray-700 mb-1">Título de la tarea</label>
              <input
                type="text"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
                data-text-selection-menu-target="taskTitle"
                placeholder="Título de la tarea"
                required
              >
            </div>

            <div class="mb-6">
              <label class="block text-sm font-medium text-gray-700 mb-1">Lista de tareas</label>
              <select
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
                data-text-selection-menu-target="todoSelect"
                required
              >
                <option value="">— Selecciona una lista —</option>
              </select>
            </div>

            <div class="flex justify-end gap-3">
              <button
                type="button"
                class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors"
                data-action="click->text-selection-menu#closeModal"
              >
                Cancelar
              </button>
              <button
                type="submit"
                class="px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
              >
                Crear tarea
              </button>
            </div>
          </form>
        </div>
      </div>
    </section>
  </div>
</div>