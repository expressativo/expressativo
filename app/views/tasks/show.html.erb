<%= render layout: 'projects/layout', locals: { project: @project, active: :todos } do %>
  <%
    case params[:from]
    when 'board'
      back_url = :back
      back_label = "Volver al tablero"
    when 'calendar'
      publication_date = @task.publication&.publication_date || Date.today
      back_url = project_publications_path(@project, year: publication_date.year, month: publication_date.month)
      back_label = "Volver al calendario"
    else
      back_url = project_todo_path(@project, @todo)
      back_label = "Volver a #{@todo.name}"
    end
  %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="lg:col-span-2 space-y-4">
      <div>
        <%= link_to back_url, class: "inline-flex items-center gap-1.5 text-sm text-gray-600 hover:text-purple-600 transition-colors mb-2" do %>
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l14 0" /><path d="M5 12l6 6" /><path d="M5 12l6 -6" /></svg>
          <span class="truncate max-w-[280px]"><%= back_label %></span>
        <% end %>
      </div>
      <%= turbo_frame_tag "#{dom_id(@task)}_show" do %>
        <%= render 'tasks/tasks_info', task: @task %>
      <% end %>

      <section
        class="bg-white border border-gray-200 rounded-2xl p-6"
        data-controller="text-selection-menu"
        data-text-selection-menu-project-id-value="<%= @project.id %>"
        data-text-selection-menu-todos-value="<%= @project.todos.map { |t| { id: t.id, name: t.name } }.to_json %>"
      >
        <div class="flex items-center gap-2 mb-4">
          <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          <h2 class="text-base font-semibold text-gray-900">Comentarios</h2>
          <% if @task.comments.any? %>
            <span class="text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full"><%= @task.comments.size %></span>
          <% end %>
        </div>

        <div id="flash-messages"></div>

        <div class="mb-4">
          <%= render 'tasks/comments/form' %>
        </div>

        <%= render 'tasks/comments/list' %>

        <%# Floating text-selection menu %>
        <div
          class="hidden fixed z-50 bg-white shadow-lg rounded-lg border border-gray-200 py-1 min-w-max"
          data-text-selection-menu-target="menu"
        >
          <button
            class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 w-full text-left transition-colors"
            data-action="click->text-selection-menu#openCreateTaskModal"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 5v14M5 12h14"/>
            </svg>
            Crear tarea
          </button>
        </div>

        <%# Create task from selection modal %>
        <div
          class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50"
          data-text-selection-menu-target="modal"
          data-action="click->text-selection-menu#backdropClick"
        >
          <div class="bg-white rounded-xl shadow-2xl p-6 max-w-md w-full mx-4">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-base font-semibold text-gray-900">Crear tarea desde selección</h3>
              <button
                type="button"
                class="text-gray-400 hover:text-gray-600 transition-colors"
                data-action="click->text-selection-menu#closeModal"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 6 6 18M6 6l12 12"/>
                </svg>
              </button>
            </div>
            <form data-action="submit->text-selection-menu#createTask">
              <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-1">Título de la tarea</label>
                <input
                  type="text"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
                  data-text-selection-menu-target="taskTitle"
                  placeholder="Título de la tarea"
                  required
                >
              </div>
              <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-1">Lista de tareas</label>
                <select
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
                  data-text-selection-menu-target="todoSelect"
                  required
                >
                  <option value="">— Selecciona una lista —</option>
                </select>
              </div>
              <div class="mb-6">
                <button
                  type="button"
                  class="flex items-center gap-1 text-sm text-gray-500 hover:text-indigo-600 transition-colors mb-2"
                  data-action="click->text-selection-menu#toggleNotes"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-text-selection-menu-target="notesToggleIcon">
                    <path d="M12 5v14M5 12h14"/>
                  </svg>
                  Agregar notas <span class="text-gray-400 font-normal">(opcional)</span>
                </button>
                <div class="hidden" data-text-selection-menu-target="notesField">
                  <textarea
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none resize-none"
                    data-text-selection-menu-target="taskNotes"
                    placeholder="Notas adicionales sobre la tarea..."
                    rows="3"
                  ></textarea>
                </div>
              </div>
              <div class="flex justify-end gap-3">
                <button
                  type="button"
                  class="button-outline"
                  data-action="click->text-selection-menu#closeModal"
                >
                  Cancelar
                </button>
                <button
                  type="submit"
                  class="button"
                >
                  Crear tarea
                </button>
              </div>
            </form>
          </div>
        </div>
      </section>
    </div>

    <aside class="space-y-4">
      <%= render 'tasks/details_sidebar', task: @task %>
    </aside>
  </div>
<% end %>
