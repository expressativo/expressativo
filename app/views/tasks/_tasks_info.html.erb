<section class="bg-white border border-gray-200 rounded-2xl p-6">
  <div class="flex items-center justify-between gap-3 mb-4 pb-3 border-b border-gray-100">
    <div class="flex items-center gap-2 text-xs text-gray-500 font-mono">
      <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
      </svg>
      <span class="text-gray-400">TASK-<%= task.id %></span>
      <span class="text-gray-300">·</span>
      <%= link_to @todo.name, project_todo_path(@project, @todo),
            class: "text-gray-500 hover:text-purple-600 transition-colors truncate max-w-[200px]" %>
    </div>

    <div class="flex items-center gap-1">
      <%= link_to edit_project_todo_task_path(@project, @todo, task),
                  data: { turbo_frame: "#{dom_id(task)}_show" },
                  title: "Editar",
                  class: "p-1.5 rounded-lg text-gray-500 hover:text-purple-600 hover:bg-purple-50 transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" /><path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z" /><path d="M16 5l3 3" /></svg>
      <% end %>
      <%= link_to project_todo_task_path(@project, @todo, task),
                  title: "Eliminar",
                  class: "p-1.5 rounded-lg text-gray-500 hover:text-red-600 hover:bg-red-50 transition-colors",
                  data: {
                    turbo_method: :delete,
                    turbo_confirm: '¿Estás seguro de que quieres eliminar esta tarea?'
                  } do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M4 7l16 0" /><path d="M10 11l0 6" /><path d="M14 11l0 6" /><path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" /><path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" /></svg>
      <% end %>
    </div>
  </div>

  <%= link_to edit_project_todo_task_path(@project, @todo, task),
              data: { turbo_frame: "#{dom_id(task)}_show" },
              class: "block group" do %>
    <div class="flex items-center gap-3">
      <span class="inline-flex w-7 h-7 items-center justify-center rounded-md border-2 flex-shrink-0 <%= task.completed? ? 'bg-emerald-500 border-emerald-500 text-white' : 'border-gray-300 group-hover:border-purple-500 bg-white' %> transition-colors">
        <% if task.completed? %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
          </svg>
        <% end %>
      </span>
      <h1 class="text-2xl md:text-3xl font-bold text-gray-900 leading-tight group-hover:text-purple-700 transition-colors <%= 'line-through text-gray-400 group-hover:text-gray-500' if task.completed? %>">
        <%= task.title %>
      </h1>
    </div>
  <% end %>

  <div class="mt-6">
    <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Descripción</h2>
    <%= link_to edit_project_todo_task_path(@project, @todo, task),
                data: { turbo_frame: "#{dom_id(task)}_show" },
                class: "block rounded-lg hover:bg-gray-50 transition-colors -mx-2 px-2 py-2" do %>
      <% if task.notes.present? %>
        <div class="prose prose-sm max-w-none text-gray-800">
          <%= task.notes %>
        </div>
      <% else %>
        <p class="text-sm text-gray-400 italic">Añade una descripción a esta tarea…</p>
      <% end %>
    <% end %>
  </div>
</section>
