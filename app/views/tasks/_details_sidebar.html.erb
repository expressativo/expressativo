<%
  boards = @project.boards.includes(:columns)
  current_column = task.column
  current_board = current_column&.board
  status_color = if task.completed?
    { bg: "bg-emerald-50", text: "text-emerald-700", dot: "bg-emerald-500", border: "border-emerald-200" }
  elsif current_column.present?
    { bg: "bg-blue-50", text: "text-blue-700", dot: "bg-blue-500", border: "border-blue-200" }
  else
    { bg: "bg-gray-50", text: "text-gray-600", dot: "bg-gray-400", border: "border-gray-200" }
  end
%>

<section class="bg-white border border-gray-200 rounded-2xl p-6">
  <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4">Detalles</h3>

  <div class="space-y-5">
    <%# Estado %>
    <div>
      <div class="text-xs text-gray-500 mb-2">Estado</div>
      <% if boards.any? %>
        <%= form_with model: [@project, @todo, task], class: "block" do |form| %>
          <%= hidden_field_tag :from, "show" %>
          <div data-controller="task-status">
            <div class="relative">
              <button
                type="button"
                data-action="click->task-status#toggleDropdown"
                data-task-status-target="button"
                class="w-full flex items-center justify-between gap-2 px-3 py-2 text-sm rounded-lg border <%= status_color[:border] %> <%= status_color[:bg] %> hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-purple-500 transition-colors">
                <span class="inline-flex items-center gap-2 min-w-0">
                  <span class="w-2 h-2 rounded-full <%= status_color[:dot] %>"></span>
                  <span class="font-medium <%= status_color[:text] %> truncate" data-task-status-target="selectedText">
                    <% if current_column.present? %>
                      <%= current_column.title %>
                    <% else %>
                      Sin estatus
                    <% end %>
                  </span>
                  <% if current_board.present? %>
                    <span class="text-xs text-gray-400 truncate">· <%= current_board.title %></span>
                  <% end %>
                </span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-500 flex-shrink-0" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <path d="M6 9l6 6l6 -6" />
                </svg>
              </button>

              <div
                data-task-status-target="dropdown"
                class="hidden absolute z-50 w-full mt-1 bg-white border border-gray-200 rounded-lg shadow-lg max-h-72 overflow-auto">
                <% boards.each do |board| %>
                  <div class="p-2 border-b border-gray-100 last:border-b-0">
                    <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider px-2 py-1">
                      <%= board.title %>
                    </div>
                    <% board.columns.each do |column| %>
                      <button
                        type="button"
                        data-action="click->task-status#selectColumn"
                        data-column-id="<%= column.id %>"
                        data-column-title="<%= column.title %>"
                        data-board-title="<%= board.title %>"
                        class="w-full text-left px-3 py-2 hover:bg-purple-50 rounded text-sm <%= 'bg-purple-100 font-medium text-purple-700' if task.column&.id == column.id %>">
                        <%= column.title %>
                        <% if task.column&.id == column.id %>
                          <span class="text-xs text-purple-600 ml-1">✓</span>
                        <% end %>
                      </button>
                    <% end %>
                  </div>
                <% end %>

                <% if task.column.present? %>
                  <div class="p-2 border-t border-gray-200">
                    <button
                      type="button"
                      data-action="click->task-status#clearStatus"
                      class="w-full text-left px-3 py-2 text-red-600 hover:bg-red-50 rounded text-sm flex items-center gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <path d="M18 6l-12 12" />
                        <path d="M6 6l12 12" />
                      </svg>
                      Quitar estatus
                    </button>
                  </div>
                <% end %>
              </div>

              <%= form.hidden_field :column_id, data: { task_status_target: "columnInput" } %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-gray-50 border border-gray-200 text-sm text-gray-500">
            <span class="w-2 h-2 rounded-full bg-gray-400"></span>
            Sin tableros
          </span>
        </div>
      <% end %>
    </div>

    <%# Campos personalizados %>
    <% project_custom_fields = @project.custom_fields %>
    <% if project_custom_fields.any? %>
      <% task_cfv_map = task.custom_field_values.index_by(&:project_custom_field_id) %>
      <div class="pt-1">
        <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Campos personalizados</div>
        <div class="space-y-3">
          <% project_custom_fields.each do |field| %>
            <%
              value_record = task_cfv_map[field.id]
              current_value = value_record&.value.to_s
              value_id = value_record&.id || 0
            %>
            <div>
              <div class="text-xs text-gray-500 mb-1"><%= field.name %></div>
              <%# Render de solo lectura para link y map %>
              <% if field.field_type == "link" && current_value.present? %>
                <%= link_to current_value, current_value, target: "_blank", rel: "noopener",
                      class: "inline-flex items-center gap-1 text-sm text-indigo-600 hover:text-indigo-800 underline underline-offset-2 truncate max-w-full" do %>
                  <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                  <%= current_value.sub(%r{^https?://}, "").truncate(40) %>
                <% end %>
              <% elsif field.field_type == "map" && current_value.present? %>
                <% embed_url = ProjectCustomField.maps_embed_url(current_value) %>
                <div class="rounded-xl overflow-hidden border border-gray-200">
                  <iframe src="<%= embed_url %>"
                          width="100%"
                          height="200"
                          style="border:0;"
                          allowfullscreen=""
                          loading="lazy"
                          referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>
                <%= link_to current_value, current_value, target: "_blank", rel: "noopener",
                      class: "inline-flex items-center gap-1 mt-1 text-xs text-gray-500 hover:text-gray-700" do %>
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                  Abrir en Google Maps
                <% end %>
              <% elsif @project.viewer?(current_user) %>
                <span class="text-sm text-gray-800"><%= current_value.presence || "—" %></span>
              <% end %>
              <% unless @project.viewer?(current_user) %>
                <%= form_with url: project_todo_task_custom_field_value_path(@project, @todo, task, value_id),
                              method: :patch,
                              class: "flex items-center gap-1.5 #{"mt-1" if %w[link map].include?(field.field_type) && current_value.present?}" do |f| %>
                  <input type="hidden" name="project_custom_field_id" value="<%= field.id %>" />
                  <% case field.field_type %>
                  <% when "text" %>
                    <input type="text"
                           name="task_custom_field_value[value]"
                           value="<%= current_value %>"
                           placeholder="—"
                           class="flex-1 min-w-0 px-2 py-1 text-sm bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500" />
                  <% when "number" %>
                    <input type="number"
                           name="task_custom_field_value[value]"
                           value="<%= current_value %>"
                           placeholder="—"
                           class="flex-1 min-w-0 px-2 py-1 text-sm bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500" />
                  <% when "date" %>
                    <input type="date"
                           name="task_custom_field_value[value]"
                           value="<%= current_value %>"
                           class="flex-1 min-w-0 px-2 py-1 text-sm bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500" />
                  <% when "select" %>
                    <select name="task_custom_field_value[value]"
                            class="flex-1 min-w-0 px-2 py-1 text-sm bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
                      <option value="">— Sin valor —</option>
                      <% field.options_list.each do |opt| %>
                        <option value="<%= opt %>" <%= "selected" if current_value == opt %>><%= opt %></option>
                      <% end %>
                    </select>
                  <% when "link", "map" %>
                    <input type="url"
                           name="task_custom_field_value[value]"
                           value="<%= current_value %>"
                           placeholder="<%= field.field_type == "map" ? "https://maps.google.com/..." : "https://" %>"
                           class="flex-1 min-w-0 px-2 py-1 text-sm bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500" />
                  <% end %>
                  <button type="submit" class="flex-shrink-0 p-1 rounded text-indigo-600 hover:bg-indigo-50 transition-colors" title="Guardar">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                  </button>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Responsables %>
    <div>
      <div class="text-xs text-gray-500 mb-2">Responsables</div>
      <%= render 'tasks/assignees', task: task %>
    </div>

    <%# Reporter %>
    <div>
      <div class="text-xs text-gray-500 mb-2">Reportado por</div>
      <div class="flex items-center gap-2">
        <% if task.created_by.present? %>
          <%= user_avatar(task.created_by, class: "w-7 h-7 rounded-full object-cover") %>
          <span class="text-sm text-gray-800 truncate">
            <%= task.created_by.full_name.presence || task.created_by.email %>
          </span>
        <% else %>
          <span class="text-sm text-gray-400 italic">Sin usuario</span>
        <% end %>
      </div>
    </div>

    <%# Fecha de vencimiento %>
    <div>
      <div class="text-xs text-gray-500 mb-2">Vence el</div>
      <% if task.due_date.present? %>
        <%
          today = Date.current
          days = (task.due_date.to_date - today).to_i
          if task.completed?
            pill = { bg: "bg-gray-50", text: "text-gray-600", border: "border-gray-200" }
          elsif days < 0
            pill = { bg: "bg-red-50", text: "text-red-700", border: "border-red-200" }
          elsif days <= 3
            pill = { bg: "bg-amber-50", text: "text-amber-700", border: "border-amber-200" }
          else
            pill = { bg: "bg-gray-50", text: "text-gray-700", border: "border-gray-200" }
          end

          due_dt = task.due_date
          has_time = due_dt.hour != 0 || due_dt.min != 0
          due_label = if has_time
            l(due_dt.to_date, format: :long) + " · " + due_dt.strftime("%H:%M")
          else
            l(due_dt.to_date, format: :long)
          end
        %>
        <div class="flex items-center gap-2 flex-wrap">
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg border <%= pill[:border] %> <%= pill[:bg] %> <%= pill[:text] %> text-sm font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <%= due_label %>
          </span>

          <%
            if has_time
              gcal_start = due_dt.utc.strftime('%Y%m%dT%H%M%SZ')
              gcal_end   = (due_dt.utc + 1.hour).strftime('%Y%m%dT%H%M%SZ')
            else
              gcal_start = due_dt.to_date.strftime('%Y%m%d')
              gcal_end   = (due_dt.to_date + 1).strftime('%Y%m%d')
            end
            gcal_url = "https://calendar.google.com/calendar/render?" + {
              action:  "TEMPLATE",
              text:    task.title,
              dates:   "#{gcal_start}/#{gcal_end}",
              details: "Tarea de Tivo: #{project_todo_task_url(@project, @todo, task)}"
            }.to_query
          %>
          <%= link_to gcal_url, target: "_blank", rel: "noopener",
                title: "Agregar a Google Calendar",
                class: "inline-flex items-center gap-1 px-2 py-1 text-xs font-medium text-blue-600 bg-blue-50 border border-blue-200 rounded-lg hover:bg-blue-100 transition-colors" do %>
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221l-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12l-6.871 4.326-2.962-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.833.941z"/>
            </svg>
            Google Calendar
          <% end %>

          <%= link_to calendar_project_todo_task_path(@project, @todo, task),
                title: "Descargar .ics para cualquier calendario",
                class: "inline-flex items-center gap-1 px-2 py-1 text-xs font-medium text-gray-600 bg-gray-50 border border-gray-200 rounded-lg hover:bg-gray-100 transition-colors" do %>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            .ics
          <% end %>
        </div>
      <% else %>
        <span class="text-sm text-gray-400 italic">Sin fecha</span>
      <% end %>
    </div>

    <%# Lista (Todo) %>
    <div>
      <div class="text-xs text-gray-500 mb-2">Lista</div>
      <%= link_to project_todo_path(@project, @todo), class: "inline-flex items-center gap-1.5 text-sm text-gray-700 hover:text-purple-600 transition-colors" do %>
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
        </svg>
        <span class="truncate"><%= @todo.name %></span>
      <% end %>
    </div>

    <div class="pt-4 border-t border-gray-100 space-y-1.5">
      <div class="flex items-center justify-between text-xs text-gray-500">
        <span>Creada</span>
        <span><%= l(task.created_at.to_date, format: :long) rescue task.created_at.strftime("%d/%m/%Y") %></span>
      </div>
      <div class="flex items-center justify-between text-xs text-gray-500">
        <span>Actualizada</span>
        <span><%= time_ago_in_words(task.updated_at) %> atrás</span>
      </div>
      <div class="flex items-center justify-between text-xs text-gray-400">
        <span>ID</span>
        <span class="font-mono">TASK-<%= task.id %></span>
      </div>
    </div>
  </div>
</section>
