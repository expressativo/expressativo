<section class="bg-white border border-gray-200 rounded-2xl p-6">
  <%= form_with model: [@project, @todo, @task], data: { turbo_frame: "#{dom_id(@task)}_show" } do |form| %>
    <%= hidden_field_tag :from, "full_form" %>
    <div class="flex items-center justify-between gap-3 mb-4 pb-3 border-b border-gray-100">
      <div class="flex items-center gap-2 text-xs text-gray-500 font-mono">
        <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
        </svg>
        <span class="text-gray-400">TASK-<%= @task.id %></span>
        <span class="text-gray-300">·</span>
        <span class="text-gray-500 truncate max-w-[200px]">Editando</span>
      </div>
      <div class="flex items-center gap-2">
        <%= link_to "Cancelar", project_todo_task_path(@project, @todo, @task),
                    class: "inline-flex items-center px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors",
                    data: { turbo_frame: "#{dom_id(@task)}_show" } %>
        <%= form.submit "Guardar",
            class: "inline-flex items-center px-3 py-1.5 text-sm font-medium text-white bg-purple-600 border border-transparent rounded-lg hover:bg-purple-700 transition-colors",
            data: { turbo_submits_with: "Guardando..." } %>
      </div>
    </div>
    <div class="flex items-center gap-3">
      <label class="flex-shrink-0 cursor-pointer">
        <%= form.check_box :completed, class: "sr-only peer" %>
        <span class="inline-flex w-7 h-7 items-center justify-center rounded-md border-2 border-gray-300 bg-white peer-checked:bg-emerald-500 peer-checked:border-emerald-500 peer-checked:text-white transition-colors">
          <svg class="w-4 h-4 opacity-0 peer-checked:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
          </svg>
        </span>
      </label>
      <%= form.text_field :title,
            class: "flex-1 text-2xl md:text-3xl font-bold text-gray-900 leading-tight bg-transparent border-0 border-b border-transparent focus:border-purple-500 focus:ring-0 focus:outline-none px-0 py-1",
            placeholder: "Describe esta tarea" %>
    </div>
    <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Vence el</label>
        <%= form.date_field :due_date, class: "input" %>
      </div>
      <div>
        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Estado</label>
        <%= render 'tasks/status_selector', form: form, task: @task %>
      </div>
    </div>
    <div class="mt-6">
      <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Descripción</label>
      <%= form.rich_text_area :notes, placeholder: "Escribe la descripción de tu tarea aquí" %>
    </div>
  </div>
  <div class="flex gap-2 mt-4">
    <%= form.submit "Guardar", class: "button", data: {
      turbo_submits_with: "Guardando..."
    }%>
    <%= link_to "Cancelar", project_todo_task_path(@project, @todo, @task), 
                class: "button-outline",
                data: { turbo_frame: "#{dom_id(@task)}_show" } %>
  </div>
<% end %>
