<div>
  <%= turbo_frame_tag "#{dom_id(@todo)}_task_form" do %>
    <div class="pt-3 border-t border-gray-100">
      <p class="text-xs font-medium text-gray-500 mb-2">¿Cómo quieres crear la tarea?</p>
      <div class="flex flex-col gap-1.5">
        <%= link_to new_project_todo_task_path(@project, @todo, blank: true),
              data: { turbo_frame: "#{dom_id(@todo)}_task_form" },
              class: "inline-flex items-center gap-2 px-3 py-2 text-sm text-gray-700 rounded-lg border border-gray-200 hover:border-purple-300 hover:bg-purple-50 hover:text-purple-700 transition-colors" do %>
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Tarea en blanco
        <% end %>

        <% @templates.each do |template| %>
          <%= link_to new_project_todo_task_path(@project, @todo, template_id: template.id),
                data: { turbo_frame: "#{dom_id(@todo)}_task_form" },
                class: "inline-flex items-center gap-2 px-3 py-2 text-sm text-gray-700 rounded-lg border border-gray-200 hover:border-purple-300 hover:bg-purple-50 hover:text-purple-700 transition-colors" do %>
            <svg class="w-4 h-4 flex-shrink-0 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            Basada en "<%= template.name %>"
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
